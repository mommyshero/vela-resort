                <p class="tour-card-route">To Takoe Bi Hot Spring (~2 km round trip walk)</p>
                <div class="tour-card-price" id="tour4-price">฿1,850 <span>/Group (1-5 People)</span></div>
                <p style="font-size: 0.92rem; color: var(--gray); margin-top: 0.5rem;">6-10 People: ฿2,500</p>
                <div class="form-group" style="margin-top: 1rem;">
                    <label style="font-size: 0.92rem; color: var(--dark-gray); font-weight: 600;">Number of People</label>
                    <select id="tour4-people" onchange="updateTourPrice(4)" style="width: 100%; padding: 0.75rem; border: 2px solid var(--light-gray); border-radius: 10px; font-size: 1.03rem;">
                        <option value="1">1 People</option>
                        <option value="2">2 People</option>
                        <option value="3">3 People</option>
                        <option value="4">4 People</option>
                        <option value="5" selected>5 People</option>
                        <option value="6">6 People</option>
                        <option value="7">7 People</option>
                        <option value="8">8 People</option>
                        <option value="9">9 People</option>
                        <option value="10">10 People</option>
                    </select>
                </div>
                <div class="tour-total-price" id="tour4-total" style="margin-top: 0.75rem; padding: 0.75rem; background: var(--yellow-light); border-radius: 10px; text-align: center;">
                    <span style="font-size: 0.92rem; color: var(--dark-gray);">PriceTotal: </span>
                    <span style="font-size: 0.91rem; font-weight: 800; color: var(--charcoal);">฿1,850</span>
