    <div id="tourItineraryModal5" class="tour-itinerary-modal" style="display: none;">
        <div class="tour-itinerary-content">
            <div class="tour-itinerary-header">
                <h3>🏔️ Doi Hua Mot Tour</h3>
                <button class="itinerary-close" onclick="toggleTourItinerary(5)">×</button>
            </div>
            <div class="tour-itinerary-body">
                <table class="itinerary-table">
                    <tr><td class="time">05:00 AM</td><td>Resort vehicle pickup (wear warm clothes!)</td></tr>
                    <tr><td class="time">05:30 AM</td><td>Arrive at Doi Hua Mot viewpoint</td></tr>
                    <tr><td class="time">05:30 – 07:30 AM</td><td>Enjoy sea of mist, sunrise, and photography</td></tr>
                    <tr><td class="time">07:30 AM</td><td>Descend from the mountain</td></tr>
                    <tr><td class="time">08:00 AM</td><td>Arrive back at resort (free to rest)</td></tr>
                </table>
                <p style="margin-top: 1rem; padding: 0.75rem; background: #FEF3C7; border-radius: 8px; color: #92400E; font-size: 0.9rem; text-align: center;">🎁 Easy walk: FREE! | 🏔️ Summit climb: ฿1,000-1,500/group</p>
            </div>
        </div>
    </div>

    <!-- Tour Detail Popup -->
    <div id="tourDetailPopup" class="tour-popup" style="display: none;">
        <div class="tour-popup-content">
            <div class="tour-popup-header">
                <h3>📋 DetailsTour</h3>
                <button class="popup-close" onclick="closeTourPopup()">×</button>
            </div>
            <div class="tour-popup-body">
                <h4 id="popupTourName">VIP Thi Lo Su 1 Day</h4>
                <table class="tour-price-table">
                    <thead>
                        <tr>
                            <th>Number of People</th>
                            <th>Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1-6 People</td>
                            <td id="popupPrice1_6">฿5,800</td>
                        </tr>
                        <tr>
                            <td>7-10 People</td>
                            <td id="popupPrice7_10">฿8,300</td>
                        </tr>
                        <tr>
                            <td>11-12 People</td>
                            <td id="popupPrice11_12">฿10,800</td>
                        </tr>
                        <tr>
                            <td>13-15 People</td>
                            <td id="popupPrice13_15">฿13,800</td>
                        </tr>
                    </tbody>
                </table>
                <div class="tour-details">
                    <h5>📝 Details</h5>
                    <ul>
                        <li>✅ VehiclePrivateReceive-Send</li>
                        <li>✅ Guide leadingVisit</li>
                        <li>✅ LunchDay</li>
