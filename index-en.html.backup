    <div id="tourItineraryModal4" class="tour-itinerary-modal" style="display: none;">
        <div class="tour-itinerary-content">
            <div class="tour-itinerary-header">
                <h3>♨️ 4x4 Vehicle Hot Spring Tour</h3>
                <button class="itinerary-close" onclick="toggleTourItinerary(4)">×</button>
            </div>
            <div class="tour-itinerary-body">
                <table class="itinerary-table">
                    <tr><td class="time">09:00 AM</td><td>Resort vehicle pickup from your accommodation</td></tr>
                    <tr><td class="time">10:00 AM</td><td>Arrive at Takhobi Hot Spring</td></tr>
                    <tr><td class="time">10:00 – 12:00 PM</td><td>Soak in natural hot springs, nature walk (~2 km)</td></tr>
                    <tr><td class="time">12:00 PM</td><td>Lunch break (self-prepared or purchase along the way)</td></tr>
                    <tr><td class="time">01:00 PM</td><td>Depart for return journey</td></tr>
                    <tr><td class="time">02:30 PM</td><td>Arrive back at resort</td></tr>
