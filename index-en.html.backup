        <!-- Palata Waterfall Section -->
        <div class="palata-info-section">
            <div class="info-card main palata">
                <div class="palata-hero-image waterfall-preview" onclick="openLightbox('palata-main.jpg', 'Palata Waterfall - 3-tier limestone waterfall')">
                    <img src="palata-main.jpg" alt="Palata Waterfall" onerror="this.src='https://via.placeholder.com/1200x600/E5E7EB/1A1A1A?text=Palata+Waterfall';">
                </div>
                <h3>💧 Palata Waterfall - Limestone waterfall of Umphang District</h3>
                <p class="highlight">Beautiful limestone waterfall in Palata Waterfall Park</p>

                <div class="info-grid">
                    <div class="info-item">
                        <i class="fas fa-water"></i>
                        <div>
                            <strong>Characteristics</strong>
                            <span>3-tier limestone waterfall</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-ruler-horizontal"></i>
                        <div>
                            <strong>Width</strong>
                            <span>Long continuous flow</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <strong>Location</strong>
                            <span>Umphang District, Tak Province</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-tree"></i>
                        <div>
                            <strong>Area</strong>
                            <span>Palata Waterfall Park</span>
                        </div>
                    </div>
                </div>

                <p class="description">Palata Waterfall is a limestone waterfall that has beauty. The highlight is its width - the waterfall width is continuous and tiered. It has clear 3 tiers. Visitors can stroll along the various tiers.</p>

