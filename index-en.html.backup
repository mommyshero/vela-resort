    <!-- Booking Modal -->
    <div id="bookingModal" class="modal-overlay" onclick="closeBookingModal(event)">
        <div class="modal-container">
            <div class="modal-header">
                <h3>📅 Book Accommodation</h3>
                <button class="modal-close" onclick="closeBookingModal()">×</button>
            </div>
            <div class="modal-body">
                <!-- Room Type Selection -->
                <div class="room-selection-row">
                    <div class="room-type-card selected" id="roomType-hytte" onclick="selectRoomType('hytte')">
                        <h3>Hytte</h3>
                        <p>5 Room • Riverside</p>
                        <button>Select</button>
                    </div>
                    <div class="room-type-card" id="roomType-hus" onclick="selectRoomType('hus')">
                        <h3>Hus</h3>
                        <p>1 Room • Field View</p>
                        <button>Select</button>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label>📅 Check-in</label>
                        <input type="date" id="checkInDate" onchange="calculatePrice(); renderCalendar();">
                    </div>
                    <div class="form-group">
                        <label>📅 Check-out</label>
                        <input type="date" id="checkOutDate" onchange="calculatePrice(); renderCalendar();">
                    </div>
                    <div class="form-group">
                        <label>👥 Number of Rooms</label>
                        <select id="bookingRooms" onchange="calculatePrice()">
                            <option value="1">1 Room</option>
                            <option value="2">2 Room</option>
                            <option value="3">3 Room</option>
                            <option value="4">4 Room</option>
                            <option value="5">5 Room</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>👤 NumberGuestRest</label>
                        <input type="number" id="bookingGuests" min="1" value="2" placeholder="Number of People">
                    </div>
                    <div class="form-group full">
                        <label>📛 Full Name</label>
                        <input type="text" id="bookingName" placeholder="EnterNameAndSurname" oninput="calculatePrice()">
                    </div>
                    <div class="form-group full">
                        <label>📞 PhoneTerms</label>
                        <input type="tel" id="bookingPhone" placeholder="EnterPhoneTerms" oninput="calculatePrice()">
                    </div>
                    <div class="form-group full">
                        <label>📧 Email (Optional)</label>
                        <input type="email" id="bookingEmail" placeholder="example@email.com">
                    </div>
                </div>

                <!-- Calendar -->
                <div class="booking-calendar" id="bookingCalendar">
                    <div class="calendar-title">
                        <i class="fas fa-calendar-alt"></i>
                        CalendarBooking (ShowNumber of RoomsAvailable)
                    </div>
                    <div class="calendar-legend">
                        <div class="calendar-legend-item">
                            <div class="calendar-legend-color weekday"></div>
                            <span>DayNormal</span>
                        </div>
                        <div class="calendar-legend-item">
                            <div class="calendar-legend-color weekend"></div>
                            <span>Weekend Holidays</span>
                        </div>
                        <div class="calendar-legend-item">
                            <div class="calendar-legend-color holiday"></div>
                            <span>Public Holidays</span>
                        </div>
                    </div>
                    <div class="calendar-grid" id="calendarGrid">
                        <div class="calendar-day-header">Ar</div>
                        <div class="calendar-day-header">จ</div>
                        <div class="calendar-day-header">อ</div>
                        <div class="calendar-day-header">พ</div>
                        <div class="calendar-day-header">Thu</div>
                        <div class="calendar-day-header">ศ</div>
                        <div class="calendar-day-header">ส</div>
                    </div>
                </div>

                <!-- Room Availability -->
                <div class="room-availability" id="roomAvailability">
                    <div class="availability-title">
                        <i class="fas fa-info-circle"></i>
                        <span>StatusRoomAvailable</span>
                    </div>
                    <div class="availability-list" id="availabilityList">
                        Please select a dateCheck-inAndCheck-out
                    </div>
                </div>

                <!-- Price Display -->
                <div class="booking-price-summary" id="roomPriceDisplay" style="display: none;">
                    <div class="booking-price-row">
                        <span>PriceAverage perNight:</span>
                        <span id="pricePerNight">฿0</span>
                    </div>
                    <div class="booking-price-row">
                        <span>Number of Nights:</span>
                        <span id="numberOfNights">0 Night</span>
                    </div>
                    <div class="booking-price-row">
                        <span>Number of Rooms:</span>
                        <span id="numberOfRooms">1 Room</span>
                    </div>
                    <div class="booking-price-row">
                        <span>Season:</span>
                        <span id="seasonType">-</span>
                    </div>
                    <div class="booking-price-row" style="border-top: 2px solid var(--light-gray); padding-top: 0.75rem; margin-top: 0.5rem;">
                        <span style="font-size: 1.19rem; font-weight: 700;">TotalAll:</span>
                        <span id="roomTotalPrice" style="font-size: 1.19rem; font-weight: 800; color: var(--charcoal);">฿0</span>
                    </div>
                </div>

                <!-- Tour Add-on -->
                <div class="tour-addon-section">
                    <div class="tour-addon-header">
                        <h4>🗺️ AddBook Tour (Optional)</h4>
                        <label class="tour-toggle">
                            <input type="checkbox" id="addTourCheckbox" onchange="toggleTourAddon()">
                            <span class="toggle-slider"></span>
                            <span class="toggle-label">Add Tour</span>
                        </label>
                    </div>

                    <div id="tourAddonContent" style="display: none; margin-top: 1rem;">
                        <div class="form-group">
                            <label>🎯 SelectTour</label>
                            <select id="tourSelector" onchange="updateTourAddonPrice()">
                                <option value="">-- SelectTour --</option>
                                <option value="1">VIP Thi Lo Su-Kotha 1 Day</option>
                                <option value="2">Join Trip Thi Lo Su (฿2,100/person)</option>
                                <option value="3">Vehicle 4x4 Thi Lo Su</option>
                                <option value="4">Vehicle 4x4 Onsen</option>
                                <option value="5">Doi Hua Mot</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>👥 Number of People</label>
                            <select id="tourPeopleAddon" onchange="updateTourAddonPrice()">
                                <option value="1">1 People</option>
                                <option value="2">2 People</option>
                                <option value="3">3 People</option>
                                <option value="4">4 People</option>
                                <option value="5">5 People</option>
                                <option value="6">6 People</option>
                                <option value="7">7 People</option>
                                <option value="8">8 People</option>
                                <option value="9">9 People</option>
                                <option value="10">10 People</option>
                                <option value="11">11 People</option>
                                <option value="12">12 People</option>
                                <option value="13">13 People</option>
                                <option value="14">14 People</option>
                                <option value="15">15 People</option>
                            </select>
                        </div>

                        <div class="tour-price-display" id="tourAddonPriceDisplay" style="display: none;">
                            <div class="tour-price-row">
                                <span>Tour fee:</span>
                                <span id="tourAddonPrice">฿0</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Booking Summary -->
                <div class="booking-summary" id="bookingSummary" style="display: none;">
                    <div class="summary-row">
                        <span class="summary-label">Rooms:</span>
                        <span class="summary-value" id="summaryItem">-</span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">DayThat:</span>
                        <span class="summary-value" id="summaryDate">-</span>
                    </div>
                    <div class="summary-row" id="summaryTourRow" style="display: none;">
                        <span class="summary-label">Book Tour:</span>
                        <span class="summary-value" id="summaryTour">-</span>
                    </div>
                    <div class="summary-row" style="border-top: 2px solid var(--charcoal); padding-top: 0.75rem; margin-top: 0.5rem;">
                        <span style="font-size: 1.19rem; font-weight: 800;">TotalAll:</span>
                        <span class="summary-value" id="summaryTotal" style="font-size: 1.19rem; font-weight: 800; color: var(--charcoal);">฿0</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <p id="confirmBtnHint" style="text-align: center; color: var(--warning); font-size: 0.9rem; margin-bottom: 1rem; font-weight: 600;">⚠️ Please enter your name and phone number to book</p>
                <button id="confirmBookingBtn" class="confirm-btn" onclick="confirmRoomBooking()" disabled style="opacity: 0.6; cursor: not-allowed;">✅ Confirm Booking</button>
            </div>
        </div>
    </div>

    <!-- Park Fee Notice Modal -->
    <div id="parkFeeModal" class="modal-overlay" style="display: none; z-index: 10001;">
        <div class="modal-container" style="max-width: 500px; text-align: center;">
            <div class="modal-header" style="background: linear-gradient(135deg, #FFD700 0%, #F59E0B 100%);">
                <h3 style="margin: 0; color: #000;">🎫 National Park Entrance Fee</h3>
                <button class="modal-close" onclick="closeParkFeeModal()" style="color: #000;">×</button>
            </div>
            <div class="modal-body" style="padding: 2.5rem; text-align: center;">
                <div style="background: #FEF3C7; border-left: 4px solid #F59E0B; padding: 2rem; margin: 1.5rem 0; border-radius: 12px;">
                    <p style="margin: 0 0 1rem 0; font-size: 1.19rem; font-weight: 600; color: #92400E;">📢 Important Notice</p>
                    <p style="margin: 0 0 1.5rem 0; color: #78350F; line-height: 1.6;">Tour price does <strong>NOT</strong> include Thi Lo Su National Park entrance fee. Please pay directly at the park entrance.</p>
                    <div style="display: flex; justify-content: center; gap: 2%; flex-wrap: wrap;">
                        <div style="background: #FFFFFF; padding: 1.3rem 1.5rem; border-radius: 12px; border: 2px solid #F59E0B;">
                            <p style="margin: 0; font-size: 0.97rem; color: #6B7280;">👨‍🦱 Adults</p>
                            <p style="margin: 0.5rem 0 0 0; font-size: 1.2rem; font-weight: 700; color: #1A1A1A;">฿400</p>
                            <p style="margin: 0; font-size: 1.04rem; color: #6B7280;">/ person</p>
                        </div>
                        <div style="background: #FFFFFF; padding: 1.3rem 1.5rem; border-radius: 12px; border: 2px solid #F59E0B;">
                            <p style="margin: 0; font-size: 0.97rem; color: #6B7280;">👶 Children</p>
                            <p style="margin: 0.5rem 0 0 0; font-size: 1.2rem; font-weight: 700; color: #1A1A1A;">฿200</p>
                            <p style="margin: 0; font-size: 1.04rem; color: #6B7280;">/ person</p>
                        </div>
                    </div>
                </div>
                <button onclick="proceedToBooking()" style="width: 100%; padding: 1.3rem; background: linear-gradient(135deg, #10B981 0%, #059669 100%); color: #FFFFFF; border: none; border-radius: 20px; font-size: 1.19rem; font-weight: 700; cursor: pointer; transition: all 0.3s; margin-top: 1rem;">
                    ✅ I Understand - Proceed to Booking
                </button>
            </div>
        </div>
    </div>

    <!-- Tour Booking Modal -->
    <div id="tourBookingModal" class="modal-overlay" style="display: none;">
        <div class="modal-container" style="max-width: 95%;">
            <div class="modal-header">
                <h3>📝 Book Tour</h3>
                <button class="modal-close" onclick="closeTourBookingModal()">×</button>
            </div>
            <div class="modal-body">
                <form id="tourBookingForm" onsubmit="submitTourBooking(event)">
                    <input type="hidden" id="bookingTourId">
                    <div class="booking-form-group">
                        <label>🗺️ NameTour</label>
                        <input type="text" id="tourBookingTourName" readonly style="background: var(--off-white);">
                    </div>
                    <div class="booking-form-group">
                        <label>📅 DayThatBook Tour</label>
                        <input type="date" id="tourBookingDate" required min="">
                    </div>
                    <div class="booking-form-group">
                        <label>👥 Number of People</label>
                        <input type="number" id="tourBookingPeople" min="1" max="15" required onchange="updateTourBookingPrice()">
                    </div>
                    <div class="booking-form-group">
                        <label>📛 Full Name</label>
                        <input type="text" id="tourBookingName" required placeholder="EnterNameAndSurname">
                    </div>
                    <div class="booking-form-group">
                        <label>📞 PhoneTerms</label>
                        <input type="tel" id="tourBookingPhone" required placeholder="EnterPhoneTerms">
                    </div>
                    <div class="booking-price-summary">
                        <div class="booking-price-row">
                            <span>PriceTotal:</span>
                            <span id="bookingTotalPrice" style="font-weight: 800; font-size: 0.76rem;">฿0</span>
                        </div>
                    </div>
                    <button type="submit" class="booking-submit-btn">✅ ConfirmBook Tour</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Contact -->
    <section class="rooms-section" id="contact">
        <div class="section-header">
            <h2 class="section-title">Contact Us</h2>
        </div>
        <div style="max-width: 600px; margin: 0 auto; text-align: center;">
            <p style="font-size: 1.19rem; color: var(--dark-gray); margin-bottom: 1.5rem;">
                📍 528 Moo 1, Umphang District, Tak Province 63170<br>
                📞 098-908-4356 (Khun Linji - Always available)<br>
