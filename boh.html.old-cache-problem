            showToast('🏨 Import Booking.com', 'กำลังนำเข้าข้อมูล...', 'info');
            // Implementation pending
        }

        function importBookingsCSV() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.csv';
            input.onchange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                showToast('📥 Import CSV', `กำลังอ่านไฟล์: ${file.name}...`, 'info');

                try {
                    const text = await readFileAsText(file);
                    const lines = text.split('\n').map(l => l.trim()).filter(l => l);
                    
                    if (lines.length < 2) {
                        showToast('⚠️ Import CSV', 'ไม่พบข้อมูลในไฟล์', 'warning');
                        return;
                    }

                    const headers = lines[0].split(',').map(h => h.trim().replace(/"/g, ''));
                    let imported = 0;
                    let skipped = 0;

                    for (let i = 1; i < lines.length; i++) {
                        const values = lines[i].split(',').map(v => v.trim().replace(/"/g, ''));
                        const row = {};
                        headers.forEach((h, idx) => row[h] = values[idx] || '');

                        try {
                            const booking = {
                                // ID
                                id: row['BookingID'] || row['booking_id'] || row['ID'] || row['id'] || row['ReservationID'] || row['reservation_id'] || row['Reservation ID'] || Date.now().toString() + imported,
                                
                                // Names (Guest vs Booker)
                                guestName: row['GuestName'] || row['guest_name'] || row['Guest Name'] || row['guest name'] || row['Customer'] || row['customer'] || row['CustomerName'] || row['customer_name'] || row['Guest'] || row['guest'] || 'Unknown',
                                bookerName: row['BookerName'] || row['booker_name'] || row['Booker Name'] || row['booker name'] || row['BookedBy'] || row['booked_by'] || row['Booked By'] || row['booked by'] || row['Booker'] || row['booker'] || row['ReservedBy'] || row['reserved_by'] || '',
                                
                                // Contact
                                phone: row['Phone'] || row['phone'] || row['Tel'] || row['tel'] || row['Mobile'] || row['mobile'] || row['Contact'] || row['contact'] || row['PhoneNumber'] || row['phone_number'] || '-',
                                email: row['Email'] || row['email'] || row['E-mail'] || row['e-mail'] || row['EmailAddress'] || row['email_address'] || row['Mail'] || row['mail'] || '',
                                
                                // Dates
                                checkIn: formatDate(row['CheckIn'] || row['check_in'] || row['Checkin'] || row['checkin'] || row['Arrival'] || row['arrival'] || row['Arrival Date'] || row['arrival_date'] || row['Check In'] || row['check in'] || row['StartDate'] || row['start_date'] || new Date()),
                                checkOut: formatDate(row['CheckOut'] || row['check_out'] || row['Checkout'] || row['checkout'] || row['Departure'] || row['departure'] || row['Departure Date'] || row['departure_date'] || row['Check Out'] || row['check out'] || row['EndDate'] || row['end_date'] || new Date()),
                                
                                // Room
                                room: mapRoom(row['Room'] || row['room'] || row['RoomType'] || row['room_type'] || row['Room Type'] || row['room type'] || row['Room Type'] || row['Accommodation'] || row['accommodation'] || 'hytte'),
                                qty: parseInt(row['Qty'] || row['qty'] || row['Rooms'] || row['rooms'] || row['RoomQty'] || row['room_qty'] || row['Room Qty'] || row['NumberOfRooms'] || row['number_of_rooms'] || '1'),
                                
                                // Guests
                                guests: parseInt(row['Guests'] || row['guests'] || row['Adults'] || row['adults'] || row['Children'] || row['children'] || row['NumberOfGuests'] || row['number_of_guests'] || row['Pax'] || row['pax'] || '2'),
                                
                                // Price
                                total: parseFloat(row['Total'] || row['total'] || row['Amount'] || row['amount'] || row['Price'] || row['price'] || row['TotalAmount'] || row['total_amount'] || row['Total Amount'] || row['GrandTotal'] || row['grand_total'] || row['Net'] || row['net'] || '0'),
                                
                                // Status & Channel
                                status: mapStatus(row['Status'] || row['status'] || row['BookingStatus'] || row['booking_status'] || row['Booking Status'] || row['State'] || row['state'] || 'pending'),
                                channel: row['Channel'] || row['channel'] || row['Source'] || row['source'] || row['BookingSource'] || row['booking_source'] || row['Booking Source'] || row['Platform'] || row['platform'] || 'CSV Import',
                                
                                // Notes
                                notes: row['Notes'] || row['notes'] || row['Remark'] || row['remark'] || row['Remarks'] || row['remarks'] || row['Note'] || row['note'] || row['Comment'] || row['comment'] || row['Comments'] || row['comments'] || row['SpecialRequests'] || row['special_requests'] || '',
                                
                                // Metadata
                                createdAt: new Date().toISOString(),
                                updatedAt: new Date().toISOString()
                            };

                            // Auto-calculate total if not provided
                            if (!booking.total || booking.total === 0) {
                                const nights = calculateNights(booking.checkIn, booking.checkOut);
                                const rate = booking.room === 'hytte' ? 950 : 1800;
                                booking.total = nights * rate * booking.qty;
                            }

                            // Auto-fill booker name if not provided
                            if (!booking.bookerName || booking.bookerName === '') {
                                booking.bookerName = booking.guestName;
                            }

                            // Check duplicate
                            const exists = bookings.find(b => b.id === booking.id);
                            if (exists) {
                                skipped++;
                                console.warn('⚠️ Duplicate booking ID:', booking.id);
                                continue;
                            }

                            // Validate required fields
                            if (!booking.guestName || booking.guestName === 'Unknown') {
                                console.warn('⚠️ Missing guest name, skipping row:', i);
                                skipped++;
                                continue;
                            }

                            bookings.push(booking);
                            imported++;
                            imported++;
                        } catch (err) {
                            console.warn('⚠️ Skip row:', i, err);
                        }
                    }

                    localStorage.setItem('vela_bookings', JSON.stringify(bookings));
                    loadDashboard();
                    loadBookings();
                    updateSummaryStats();

                    // Calculate total revenue
                    const totalRevenue = bookings.reduce((sum, b) => sum + (parseFloat(b.total) || 0), 0);

                    let msg = `✅ Import สำเร็จ! ${imported} รายการ`;
                    if (skipped > 0) msg += ` (ข้าม ${skipped} รายการที่ซ้ำหรือไม่สมบูรณ์)`;
                    msg += ` | รวมรายได้ ฿${totalRevenue.toLocaleString()}`;
                    
                    showToast('📥 Import CSV', msg, 'success');
                    
                    console.log(`✅ Import complete: ${imported} bookings, ${skipped} skipped`);
                } catch (error) {
                    console.error('❌ Import CSV error:', error);
                    showToast('❌ Import CSV', `เกิดข้อผิดพลาด: ${error.message}`, 'error');
                }
            };
            input.click();
        }

        function readFileAsText(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () => resolve(reader.result);
                reader.onerror = reject;
                reader.readAsText(file);
            });
        }

        function mapRoom(room) {
            const r = room.toLowerCase();
            if (r.includes('hus')) return 'hus';
            return 'hytte';
        }

        function mapStatus(status) {
            const s = status.toLowerCase();
            if (s.includes('confirm')) return 'confirmed';
            if (s.includes('check-in') || s.includes('checked-in')) return 'checked-in';
            if (s.includes('check-out') || s.includes('checked-out')) return 'checked-out';
            if (s.includes('cancel')) return 'cancelled';
            return 'pending';
        }

        function formatDate(dateStr) {
            if (!dateStr) return new Date().toISOString().split('T')[0];
            try {
                if (typeof dateStr === 'number') {
                    const excelEpoch = new Date(1899, 11, 30);
                    return new Date(excelEpoch.getTime() + (dateStr * 86400000)).toISOString().split('T')[0];
                }
                const date = new Date(dateStr);
                if (isNaN(date.getTime())) return new Date().toISOString().split('T')[0];
