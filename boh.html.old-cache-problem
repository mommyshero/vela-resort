        function handleBookingSubmit(event) {
            event.preventDefault();

            const booking = {
                id: document.getElementById('bookingId').value || Date.now().toString(),
                guestName: document.getElementById('bookingGuestName').value,
                bookerName: document.getElementById('bookingBookerName').value || document.getElementById('bookingGuestName').value,
                phone: document.getElementById('bookingPhone').value,
                email: document.getElementById('bookingEmail').value || '',
                checkIn: document.getElementById('bookingCheckin').value,
                checkOut: document.getElementById('bookingCheckout').value,
                room: document.getElementById('bookingRoom').value,
                qty: parseInt(document.getElementById('bookingQty').value),
                guests: parseInt(document.getElementById('bookingGuests').value) || 2,
                channel: document.getElementById('bookingChannel').value,
                status: document.getElementById('bookingStatus').value,
                notes: document.getElementById('bookingNotes').value || '',
                createdAt: new Date().toISOString()
            };

            // Calculate total
            const nights = calculateNights(booking.checkIn, booking.checkOut);
            const rate = booking.room === 'hytte' ? 950 : 1800;
            booking.total = nights * rate * booking.qty;

            // Check if editing or new
            const existingIndex = bookings.findIndex(b => b.id === booking.id);
            if (existingIndex >= 0) {
                bookings[existingIndex] = booking;
                showToast('✅ แก้ไขสำเร็จ', 'อัพเดทข้อมูลการจองแล้ว', 'success');
            } else {
                bookings.push(booking);
                showToast('✅ จองสำเร็จ', 'เพิ่มการจองใหม่แล้ว', 'success');
            }

            saveBookings();
            loadBookings();
            loadDashboard();
            updateSummaryStats();

            // Reset form
            document.getElementById('bookingId').value = '';
            event.target.reset();
        }

