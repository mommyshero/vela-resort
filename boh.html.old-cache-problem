<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VELA BOH - Back Office System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --white: #FFFFFF;
            --yellow: #FFD700;
            --yellow-light: #FFF9E6;
            --yellow-dark: #E6C200;
            --black: #1A1A1A;
            --light-gray: #F3F4F6;
            --gray: #9CA3AF;
            --success: #10B981;
            --success-light: #D1FAE5;
            --danger: #EF4444;
            --danger-light: #FEE2E2;
            --warning: #F59E0B;
            --warning-light: #FEF3C7;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: var(--white); color: var(--black); line-height: 1.6; }

        /* Login Page */
        .login-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--black) 0%, #4B4B4B 100%);
        }
        .login-container {
            background: var(--white);
            padding: 3rem;
            border-radius: 24px;
            box-shadow: 0 25px 80px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 450px;
            text-align: center;
        }
        .login-logo {
            width: 100px;
            height: 100px;
            background: var(--yellow-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
        }
        .login-logo-icon { font-size: 3rem; }
        .login-title { font-size: 2rem; font-weight: 800; color: var(--black); margin-bottom: 0.5rem; }
        .login-subtitle { color: var(--gray); font-size: 0.95rem; margin-bottom: 2rem; }
        .login-form { display: flex; flex-direction: column; gap: 1.5rem; }
        .login-input {
            padding: 1rem 1.5rem;
            border: 2px solid var(--light-gray);
            border-radius: 14px;
            font-size: 1rem;
            transition: all 0.3s;
        }
        .login-input:focus {
            outline: none;
            border-color: var(--yellow);
            box-shadow: 0 0 0 4px var(--yellow-light);
        }
        .login-btn {
            padding: 1rem 2rem;
            background: linear-gradient(135deg, var(--black) 0%, #4B5563 100%);
            color: var(--white);
            border: none;
            border-radius: 14px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
        }
        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(26, 26, 26, 0.3);
        }

        /* Layout */
        .boh-layout { display: none; min-height: 100vh; }
        .boh-layout.active { display: flex; }
        .boh-sidebar {
            width: 320px;
            background: var(--white);
            border-right: 1px solid var(--light-gray);
            padding: 2rem 1.5rem;
            overflow-y: auto;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 100;
        }
        .boh-sidebar-header { margin-bottom: 2rem; }
        .boh-sidebar-logo { font-size: 1.75rem; font-weight: 800; color: var(--black); letter-spacing: 0.1em; }
        .boh-sidebar-subtitle { font-size: 0.85rem; color: var(--gray); margin-top: 0.25rem; }

        .boh-home-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 1rem;
            background: var(--black);
            color: var(--white);
            border-radius: 14px;
            text-decoration: none;
            font-weight: 700;
            margin-bottom: 1.5rem;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(26, 26, 26, 0.3);
            cursor: pointer;
        }
        .boh-home-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(26, 26, 26, 0.4);
            background: var(--yellow);
            color: var(--black);
        }

        .boh-menu { display: flex; flex-direction: column; gap: 0.5rem; }
        .boh-menu-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem;
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            color: var(--black);
            position: relative;
            z-index: 10;
        }
        .boh-menu-item:hover { background: var(--light-gray); }
        .boh-menu-item.active { background: var(--yellow); }
        .boh-menu-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
            background: var(--light-gray);
        }
        .boh-menu-content { flex: 1; }
        .boh-menu-title { font-weight: 700; font-size: 0.95rem; }
        .boh-menu-subtitle { font-size: 0.75rem; color: var(--gray); margin-top: 0.15rem; }
        .boh-menu-badge {
            background: var(--danger);
            color: var(--white);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 0.25rem 0.5rem;
            border-radius: 20px;
            min-width: 24px;
            text-align: center;
        }

        .boh-main {
            flex: 1;
            margin-left: 320px;
            padding: 2rem 3rem;
            min-height: 100vh;
            background: var(--light-gray);
        }

        /* Content Sections */
        .content-section { display: none; }
        .content-section.active { display: block; }

        .boh-header {
            margin-bottom: 2rem;
            background: var(--white);
            padding: 2rem;
            border-radius: 20px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.05);
        }
        .boh-title {
            font-size: 2rem;
            font-weight: 800;
            color: var(--black);
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
        }
        .boh-title-icon { font-size: 2.5rem; }
        .boh-description { color: var(--gray); font-size: 1rem; }

        /* Buttons */
        .btn {
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        .btn-primary { background: var(--black); color: var(--white); }
        .btn-primary:hover { background: var(--yellow); color: var(--black); }
        .btn-success { background: var(--success); color: var(--white); }
        .btn-success:hover { background: #059669; }
        .btn-danger { background: var(--danger); color: var(--white); }
        .btn-danger:hover { background: #DC2626; }
        .btn-black { background: var(--black); color: var(--white); }
        .btn-black:hover { background: var(--yellow); color: var(--black); }
        .btn-secondary { background: var(--light-gray); color: var(--black); }
        .btn-secondary:hover { background: var(--gray); color: var(--white); }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        .stat-card {
            background: var(--white);
            padding: 2rem;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.05);
            text-align: center;
        }
        .stat-value { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; }
        .stat-label { color: var(--gray); font-size: 0.9rem; font-weight: 600; }

        /* Form Card */
        .form-card {
            background: var(--white);
            padding: 2rem;
            border-radius: 20px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.05);
            margin-bottom: 2rem;
        }
        .form-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--black);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }
        .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
        .form-group.full { grid-column: 1 / -1; }
        .form-label { font-weight: 600; font-size: 0.9rem; color: var(--black); }
        .form-input, .form-select {
            padding: 0.75rem 1rem;
            border: 2px solid var(--light-gray);
            border-radius: 12px;
            font-size: 1rem;
            transition: all 0.3s;
        }
        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: var(--yellow);
            box-shadow: 0 0 0 4px var(--yellow-light);
        }
        .form-btn {
            padding: 1rem 2rem;
            background: linear-gradient(135deg, var(--black) 0%, #4B5563 100%);
            color: var(--white);
            border: none;
            border-radius: 14px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            width: 100%;
        }
        .form-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(26, 26, 26, 0.3);
        }

        /* Table */
        .table-container { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 1rem; text-align: left; border-bottom: 1px solid var(--light-gray); }
        th { background: var(--light-gray); font-weight: 700; font-size: 0.85rem; color: var(--black); }
        tr:hover { background: var(--yellow-light); }

        /* Status Badge */
        .status-badge {
            padding: 0.35rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            display: inline-block;
        }
        .status-pending { background: var(--warning-light); color: var(--warning); }
        .status-confirmed { background: var(--success-light); color: var(--success); }
        .status-checked-in { background: var(--success-light); color: var(--success); }
        .status-checked-out { background: var(--light-gray); color: var(--gray); }
        .status-cancelled { background: var(--danger-light); color: var(--danger); }

        /* Toast */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 10000;
        }
        .toast {
            background: var(--black);
            color: var(--white);
            padding: 1rem 1.5rem;
            border-radius: 12px;
            margin-bottom: 0.75rem;
            box-shadow: 0 8px 30px rgba(0,0,0,0.2);
            animation: slideIn 0.3s ease;
            min-width: 300px;
        }
        .toast.success { background: var(--success); }
        .toast.error { background: var(--danger); }
        .toast.warning { background: var(--warning); }
        @keyframes slideIn {
            from { transform: translateX(400px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        /* Mobile */
        @media (max-width: 768px) {
            .boh-sidebar { transform: translateX(-100%); transition: transform 0.3s ease; }
            .boh-sidebar.mobile-open { transform: translateX(0); }
            .boh-main { margin-left: 0; padding: 1.5rem; }
            .boh-menu-toggle { display: block; }
        }

        /* Debug Section */
        .debug-section {
            margin-top: 2rem;
            padding: 1rem;
            background: #f0f0f0;
            border-radius: 8px;
            text-align: center;
        }
        .debug-btn {
            padding: 0.5rem 1rem;
            background: #ff0000;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            margin: 0.25rem;
        }
    </style>
</head>
<body>
    <!-- Login Page -->
    <div id="loginPage" class="login-page">
        <div class="login-container">
            <div class="login-logo">
                <div class="login-logo-icon">🔑</div>
            </div>
            <h1 class="login-title">VELA BOH</h1>
            <p class="login-subtitle">Back Office System - เวลา รีสอร์ท อุ้มผาง</p>
            <form class="login-form" onsubmit="handleLogin(event)">
                <input type="text" id="loginUsername" class="login-input" placeholder="ชื่อผู้ใช้" required>
                <input type="password" id="loginPassword" class="login-input" placeholder="รหัสผ่าน" required>
                <button type="submit" class="login-btn">เข้าสู่ระบบ</button>
            </form>
        </div>
    </div>

    <!-- Main Layout -->
    <div id="bohLayout" class="boh-layout">
        <!-- Sidebar -->
        <aside class="boh-sidebar">
            <div class="boh-sidebar-header">
                <div class="boh-sidebar-logo">VELA</div>
                <div class="boh-sidebar-subtitle">Back Office System</div>
            </div>

            <a href="index.html" class="boh-home-btn">
                <span>🏠</span>
                <span>หน้าแรก</span>
            </a>

            <nav class="boh-menu" id="bohMenu">
                <div class="boh-menu-item active" data-section="dashboard">
                    <div class="boh-menu-icon">📊</div>
                    <div class="boh-menu-content">
                        <div class="boh-menu-title">แดชบอร์ด</div>
                        <div class="boh-menu-subtitle">ภาพรวมระบบ</div>
                    </div>
                </div>
                <div class="boh-menu-item" data-section="bookings">
                    <div class="boh-menu-icon">📝</div>
                    <div class="boh-menu-content">
                        <div class="boh-menu-title">การจอง</div>
                        <div class="boh-menu-subtitle">จัดการการจอง</div>
                    </div>
                    <span class="boh-menu-badge" id="pendingBadge">0</span>
                </div>
                <div class="boh-menu-item" data-section="calendar">
                    <div class="boh-menu-icon">📅</div>
                    <div class="boh-menu-content">
                        <div class="boh-menu-title">ปฏิทิน</div>
                        <div class="boh-menu-subtitle">Room Calendar</div>
                    </div>
                </div>
                <div class="boh-menu-item" data-section="petty">
                    <div class="boh-menu-icon">💵</div>
                    <div class="boh-menu-content">
                        <div class="boh-menu-title">บัญชีรายย่อย</div>
                        <div class="boh-menu-subtitle">Petty Cash</div>
                    </div>
                </div>
                <div class="boh-menu-item" data-section="accounting">
                    <div class="boh-menu-icon">💰</div>
                    <div class="boh-menu-content">
                        <div class="boh-menu-title">บัญชีหลัก</div>
                        <div class="boh-menu-subtitle">General Ledger</div>
                    </div>
                </div>
                <div class="boh-menu-item" data-section="settings">
                    <div class="boh-menu-icon">⚙️</div>
                    <div class="boh-menu-content">
                        <div class="boh-menu-title">ตั้งค่า</div>
                        <div class="boh-menu-subtitle">การตั้งค่าระบบ</div>
                    </div>
                </div>
            </nav>

            <div class="debug-section">
                <button class="debug-btn" onclick="testMenu()">🧪 ทดสอบปุ่ม</button>
                <p style="font-size: 0.75rem; color: #666; margin-top: 0.5rem;">คลิกเพื่อทดสอบ JavaScript</p>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="boh-main">
            <!-- Dashboard -->
            <section class="content-section active" id="dashboard">
                <div class="boh-header">
                    <h1 class="boh-title"><span class="boh-title-icon">📊</span> แดชบอร์ด</h1>
                    <p class="boh-description">ภาพรวมการจองและรายได้ของ Vela Resort</p>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value" id="dashBookings" style="color: var(--black);">0</div>
                        <div class="stat-label">📝 การจองเดือนนี้</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="dashRevenue" style="color: var(--success);">฿0</div>
                        <div class="stat-label">💰 รายได้เดือนนี้</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="dashPending" style="color: var(--warning);">0</div>
                        <div class="stat-label">⏳ รอการยืนยัน</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="dashCheckedIn" style="color: var(--black);">0</div>
                        <div class="stat-label">✅ เช็คอินแล้ว</div>
                    </div>
                </div>

                <div class="form-card">
                    <h2 class="form-title">🔄 Sync ข้อมูล</h2>
                    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                        <button class="btn btn-success" onclick="syncFromWebsite()">🔄 Sync จากเว็บ</button>
                        <button class="btn btn-primary" onclick="importFromBookingCom()">🏨 Import Booking.com</button>
                        <button class="btn btn-black" onclick="clearAllData()">🗑️ ลบข้อมูลทั้งหมด</button>
                    </div>
                    <p style="margin-top: 1rem; color: var(--gray); font-size: 0.85rem;">
                        🟢 Auto-Sync: ทุก 30 วินาที | Sync ล่าสุด: <span id="lastSyncTime">-</span>
                    </p>
                </div>
            </section>

            <!-- Bookings -->
            <section class="content-section" id="bookings">
                <div class="boh-header">
                    <h1 class="boh-title"><span class="boh-title-icon">📝</span> บันทึกการเข้าพักของลูกค้า</h1>
                    <p class="boh-description">จัดการการจอง ติดตามสถานะ และวิเคราะห์ช่องทางจอง</p>
                </div>

                <!-- Summary Stats -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value" id="totalBookings" style="color: var(--black);">0</div>
                        <div class="stat-label">📊 การจองทั้งหมด</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="totalRevenue" style="color: var(--success);">฿0</div>
                        <div class="stat-label">💰 รายได้รวม</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="pendingBookings" style="color: var(--warning);">0</div>
                        <div class="stat-label">⏳ รอยืนยัน</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="checkedInBookings" style="color: var(--black);">0</div>
                        <div class="stat-label">✅ เช็คอินแล้ว</div>
                    </div>
                </div>

                <!-- Import Section -->
                <div class="form-card">
                    <h2 class="form-title">📥 นำเข้าข้อมูล</h2>
                    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                        <button class="btn btn-primary" onclick="importBookingsCSV()">📊 Import CSV</button>
                        <button class="btn btn-success" onclick="syncFromWebsite()">🔄 Sync จากเว็บ</button>
                        <button class="btn btn-black" onclick="importFromBookingCom()">🏨 Import Booking.com</button>
                    </div>
                    <p style="margin-top: 0.75rem; color: var(--gray); font-size: 0.85rem;">
                        📋 รูปแบบ CSV: BookingID,GuestName,BookerName,Phone,CheckIn,CheckOut,Room,Qty,Total,Channel,Status
                    </p>
                </div>

                <!-- Channel Statistics -->
                <div class="form-card">
                    <h2 class="form-title">📊 สถิติช่องทางจอง</h2>
                    <div class="stats-grid" id="channelStats" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
                        <!-- Populated by JavaScript -->
                    </div>
                    <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center;" id="channelLegend">
                        <!-- Populated by JavaScript -->
                    </div>
                </div>

                <!-- Add/Edit Booking Form -->
                <div class="form-card">
                    <h2 class="form-title">➕ เพิ่ม/แก้ไข การจอง</h2>
                    <form class="form-grid" onsubmit="handleBookingSubmit(event)">
                        <input type="hidden" id="bookingId">
                        <div class="form-group">
                            <label class="form-label">👤 ชื่อลูกค้า (ผู้เข้าพัก)</label>
                            <input type="text" class="form-input" id="bookingGuestName" placeholder="ชื่อลูกค้า" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">📝 ชื่อคนจอง</label>
                            <input type="text" class="form-input" id="bookingBookerName" placeholder="ชื่อคนจอง (ถ้าต่างจากลูกค้า)">
                        </div>
                        <div class="form-group">
                            <label class="form-label">📞 เบอร์โทรศัพท์</label>
                            <input type="tel" class="form-input" id="bookingPhone" placeholder="08X-XXX-XXXX" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">📧 Email</label>
                            <input type="email" class="form-input" id="bookingEmail" placeholder="email@example.com">
                        </div>
                        <div class="form-group">
                            <label class="form-label">📅 วันเช็คอิน</label>
                            <input type="date" class="form-input" id="bookingCheckin" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">📅 วันเช็คเอาท์</label>
                            <input type="date" class="form-input" id="bookingCheckout" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">🏠 ห้องพัก</label>
                            <select class="form-select" id="bookingRoom" required>
                                <option value="">-- เลือกห้องพัก --</option>
                                <option value="hytte">🏠 Hytte (5 ห้อง)</option>
                                <option value="hus">🏡 Hus (1 ห้อง)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">🔢 จำนวนห้อง</label>
                            <input type="number" class="form-input" id="bookingQty" min="1" max="5" value="1" required>
                        </div>
                        <div class="form-group">
