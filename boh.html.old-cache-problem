            showToast('📥 Export PDF', 'กำลังดาวน์โหลด...', 'info');
            // Implementation pending
        }

        // ==================== CALENDAR ====================
        function loadCalendar() {
            const container = document.getElementById('calendarView');
            if (!container) return;

            // Simple calendar view
            const now = new Date();
            const month = now.toLocaleString('th-TH', { month: 'long', year: 'numeric' });

            let html = `<h3 style="text-align: center; margin-bottom: 1rem;">📅 ${month}</h3>`;
            html += '<div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.5rem; text-align: center;">';
            html += '<div style="font-weight: 700;">จ.</div><div style="font-weight: 700;">อ.</div><div style="font-weight: 700;">พ.</div>';
            html += '<div style="font-weight: 700;">พฤ.</div><div style="font-weight: 700;">ศ.</div><div style="font-weight: 700;">ส.</div><div style="font-weight: 700;">อา.</div>';

            const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
            const firstDay = new Date(now.getFullYear(), now.getMonth(), 1).getDay();

            for (let i = 0; i < firstDay - 1; i++) {
                html += '<div></div>';
            }

            for (let day = 1; day <= daysInMonth; day++) {
                const dateStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const dayBookings = bookings.filter(b => b.checkIn <= dateStr && b.checkOut > dateStr);
                const hasBooking = dayBookings.length > 0;
                const isToday = dateStr === new Date().toISOString().split('T')[0];

                let bg = 'var(--light-gray)';
                if (hasBooking) bg = 'var(--yellow)';
                if (isToday) bg = 'var(--black)';

                html += `<div style="padding: 0.75rem; background: ${bg}; border-radius: 8px; min-height: 60px;">`;
                html += `<div style="font-weight: 700;">${day}</div>`;
                if (hasBooking) {
                    html += `<div style="font-size: 0.75rem; margin-top: 0.25rem;">📝 ${dayBookings.length}</div>`;
                }
                html += '</div>';
            }

            html += '</div>';
            container.innerHTML = html;
        }

        // ==================== ACCOUNTING ====================
        function loadAccounting() {
            const container = document.getElementById('accountingSummary');
            if (!container) return;

            const income = pettyCash.filter(p => p.type === 'income').reduce((sum, p) => sum + parseFloat(p.amount), 0);
            const expense = pettyCash.filter(p => p.type === 'expense').reduce((sum, p) => sum + parseFloat(p.amount), 0);

            let html = '<div class="stats-grid">';
            html += `<div class="stat-card"><div class="stat-value" style="color: var(--success);">฿${income.toLocaleString()}</div><div class="stat-label">💰 รายรับรวม</div></div>`;
            html += `<div class="stat-card"><div class="stat-value" style="color: var(--danger);">฿${expense.toLocaleString()}</div><div class="stat-label">💸 รายจ่ายรวม</div></div>`;
            html += `<div class="stat-card"><div class="stat-value" style="color: var(--black);">฿${(income - expense).toLocaleString()}</div><div class="stat-label">💰 กำไร/ขาดทุน</div></div>`;
            html += '</div>';

            container.innerHTML = html;
        }

        // ==================== UTILITIES ====================
        function calculateNights(checkIn, checkOut) {
            const start = new Date(checkIn);
            const end = new Date(checkOut);
            const diff = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
            return diff > 0 ? diff : 1;
        }

        function formatDate(dateStr) {
            if (!dateStr) return '-';
            try {
                if (typeof dateStr === 'number') {
                    const excelEpoch = new Date(1899, 11, 30);
                    return new Date(excelEpoch.getTime() + (dateStr * 86400000)).toLocaleDateString('th-TH');
                }
                const date = new Date(dateStr);
                if (isNaN(date.getTime())) return dateStr;
                return date.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' });
            } catch (e) {
                return dateStr;
            }
        }

        function showToast(icon, message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `<div style="font-size: 1.2rem; margin-bottom: 0.25rem;">${icon}</div><div style="font-weight: 600;">${message}</div>`;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }

        // ==================== INITIALIZATION ====================
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🔵 DOM Loaded - Initializing BOH...');
            setupNavigation();
            console.log('✅ Initialization complete');
        });
    </script>
