                <p style="font-size: 0.85rem; color: var(--gray); margin-top: 0.5rem;">6-10 คน: ฿2,500</p>
                <div class="form-group" style="margin-top: 1rem;">
                    <label style="font-size: 0.85rem; color: var(--dark-gray); font-weight: 600;">จำนวนคน</label>
                    <select id="tour4-people" onchange="updateTourPrice(4)" style="width: 100%; padding: 0.75rem; border: 2px solid var(--light-gray); border-radius: 10px; font-size: 0.95rem;">
