                <p style="margin: 0; font-size: 0.9rem; color: var(--dark-gray);"><strong>🤖 สวัสดีครับ! ยินดีต้อนรับสู่ Vela Resort</strong></p>
                <p style="margin: 0.5rem 0 0; font-size: 0.9rem; color: var(--dark-gray);"><strong>ถาม AI เกี่ยวกับ:</strong></p>
                <ul style="margin: 0.5rem 0 0; padding-left: 1.25rem; font-size: 0.85rem; color: var(--gray);">
                    <li>🏨 ห้องพัก ราคา และความพร้อม</li>
                    <li>🗺️ ทัวร์ต่างๆ โปรแกรมและราคา</li>
                    <li>📅 การจอง กติกา และวิธีการ</li>
                    <li>📍 สถานที่ท่องเที่ยวใกล้เคียง</li>
                    <li>❓ คำถามทั่วไปเกี่ยวกับรีสอร์ท</li>
                </ul>
                <p style="margin: 0.75rem 0 0; font-size: 0.85rem; color: #667eea; font-weight: 600;">💬 พิมพ์คำถามของคุณด้านล่าง AI จะตอบทันที!</p>
            </div>
        </div>
        <div style="padding: 1rem; border-top: 1px solid var(--light-gray); background: white;">
            <div style="display: flex; gap: 0.5rem;">
                <input type="text" id="chatInput" placeholder="🤖 ถาม AI เกี่ยวกับห้องพัก, ทัวร์, การจอง..." style="flex: 1; padding: 0.75rem; border: 2px solid var(--light-gray); border-radius: 12px; font-size: 0.9rem;" onkeypress="if(event.key==='Enter')sendChat()">
                <button onclick="sendChat()" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 0.75rem 1rem; border-radius: 12px; cursor: pointer; font-size: 1rem;">ส่ง</button>
            </div>
        </div>
    </div>
    
    <script>
        // Room pricing by season
        const pricing = {
            hytte: {
                green: { weekday: 750, weekend: 950 },
                high: { weekday: 1250, weekend: 1500 }
            },
            hus: {
                green: { weekday: 1200, weekend: 1800 },
                high: { weekday: 2100, weekend: 2500 }
            }
        };
        
        // Thai Government Holidays 2024-2025-2026 (Official)
        const holidays = [
            // 2024
            '2024-01-01', // New Year's Day
            '2024-02-24', // Makha Bucha Day
            '2024-04-06', // Chakri Memorial Day
            '2024-04-13', // Songkran Festival
            '2024-04-14', // Songkran Festival
            '2024-04-15', // Songkran Festival
            '2024-05-01', // Labour Day
            '2024-05-04', // Coronation Day
            '2024-05-22', // Visakha Bucha Day
            '2024-06-03', // H.M. Queen Suthida's Birthday
            '2024-07-20', // Asarnha Bucha Day
            '2024-07-21', // Buddhist Lent Day
            '2024-07-28', // H.M. King's Birthday
            '2024-08-12', // H.M. Queen Sirikit's Birthday / Mother's Day
            '2024-10-13', // H.M. King Bhumibol's Memorial Day
            '2024-10-23', // Chulalongkorn Day
            '2024-12-05', // H.M. King Bhumibol's Birthday / Father's Day
            '2024-12-10', // Constitution Day
            '2024-12-31', // New Year's Eve
            // 2025
            '2025-01-01', // New Year's Day
            '2025-02-12', // Makha Bucha Day
            '2025-04-06', // Chakri Memorial Day
            '2025-04-13', // Songkran Festival
            '2025-04-14', // Songkran Festival
            '2025-04-15', // Songkran Festival
            '2025-05-01', // Labour Day
            '2025-05-05', // Coronation Day
            '2025-06-03', // H.M. Queen Suthida's Birthday
            '2025-06-11', // Visakha Bucha Day
            '2025-07-20', // Asarnha Bucha Day
            '2025-07-21', // Buddhist Lent Day
            '2025-07-28', // H.M. King's Birthday
            '2025-08-12', // H.M. Queen Sirikit's Birthday / Mother's Day
            '2025-10-13', // H.M. King Bhumibol's Memorial Day
            '2025-10-23', // Chulalongkorn Day
            '2025-12-05', // H.M. King Bhumibol's Birthday / Father's Day
            '2025-12-10', // Constitution Day
            '2025-12-31', // New Year's Eve
            // 2026
            '2026-01-01', // New Year's Day
            '2026-02-26', // Makha Bucha Day
            '2026-04-06', // Chakri Memorial Day
            '2026-04-13', // Songkran Festival
            '2026-04-14', // Songkran Festival
            '2026-04-15', // Songkran Festival
            '2026-05-01', // Labour Day
            '2026-05-05', // Coronation Day
            '2026-06-03', // H.M. Queen Suthida's Birthday
            '2026-06-20', // Visakha Bucha Day
            '2026-07-09', // Asarnha Bucha Day
            '2026-07-10', // Buddhist Lent Day
            '2026-07-28', // H.M. King's Birthday
            '2026-08-12', // H.M. Queen Sirikit's Birthday / Mother's Day
            '2026-10-13', // H.M. King Bhumibol's Memorial Day
            '2026-10-23', // Chulalongkorn Day
            '2026-12-05', // H.M. King Bhumibol's Birthday / Father's Day
            '2026-12-10', // Constitution Day
            '2026-12-31'  // New Year's Eve
        ];
        
        // Gallery
        const galleryItems = [
            { type: 'photo', src: 'gallery-1.jpg', title: 'Vela Resort View' },
            { type: 'photo', src: 'gallery-2.jpg', title: 'Room' },
            { type: 'video', src: 'video-1.mp4', thumb: 'video-thumb-1.jpg', title: 'Video Tour' },
            { type: 'photo', src: 'gallery-3.jpg', title: 'Thi Lo Su' },
            { type: 'photo', src: 'gallery-4.jpg', title: 'Doi Hua Mot' },
            { type: 'video', src: 'video-2.mp4', thumb: 'video-thumb-2.jpg', title: 'Room Tour' }
        ];
        let currentLightboxIndex = 0;
        
        function filterGallery(type) {
            document.querySelectorAll('.gallery-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            document.querySelectorAll('.gallery-item').forEach(item => {
                // Show if 'all' or matches type, or if type is 'photo' show view/adventure
                if (type === 'all') {
                    item.style.display = 'block';
                } else if (type === 'photo') {
                    // Legacy support - show all non-video items
                    item.style.display = (item.dataset.type !== 'video') ? 'block' : 'none';
                } else {
                    item.style.display = (item.dataset.type === type) ? 'block' : 'none';
                }
            });
        }
        
        function openLightbox(index) {
            currentLightboxIndex = index;
            const item = galleryItems[index];
            const lightbox = document.getElementById('lightbox');
            const content = document.getElementById('lightboxContent');
            if(item.type === 'video') {
                content.innerHTML = `<video controls autoplay><source src="${item.src}" type="video/mp4"></video>`;
            } else {
                content.innerHTML = `<img src="${item.src}" alt="${item.title}">`;
            }
            lightbox.classList.add('active');
        }
        
        function closeLightbox(e) {
            if (!e || e.target.id === 'lightbox' || e.target.classList.contains('lightbox-close')) {
                document.getElementById('lightbox').classList.remove('active');
                document.getElementById('lightboxContent').innerHTML = '';
            }
        }
        
        function navigateLightbox(delta) {
            currentLightboxIndex += delta;
            if (currentLightboxIndex < 0) currentLightboxIndex = galleryItems.length - 1;
            if (currentLightboxIndex >= galleryItems.length) currentLightboxIndex = 0;
            openLightbox(currentLightboxIndex);
        }
        
        // Weather API - Umphang, Tak Province
        async function fetchUmphangWeather() {
            try {
                // Using Open-Meteo API (free, no API key required)
                // Umphang coordinates: 15.7833° N, 98.1500° E
                const response = await fetch('https://api.open-meteo.com/v1/forecast?latitude=15.7833&longitude=98.15&current_weather=true');
                const data = await response.json();
                
                if (data.current_weather) {
                    const temp = Math.round(data.current_weather.temperature);
                    const weatherCode = data.current_weather.weathercode;
                    
                    // Update temperature
                    document.getElementById('weatherTemp').textContent = `${temp}°C`;
                    
                    // Update weather icon based on weather code
                    const weatherIcons = {
                        0: '☀️',  // Clear sky
                        1: '🌤️',  // Mainly clear
                        2: '⛅',  // Partly cloudy
                        3: '☁️',  // Overcast
                        45: '🌫️', // Fog
                        48: '🌫️', // Depositing rime fog
                        51: '🌦️', // Light drizzle
                        53: '🌦️', // Moderate drizzle
                        55: '🌧️', // Dense drizzle
                        61: '🌧️', // Slight rain
                        63: '🌧️', // Moderate rain
                        65: '🌧️', // Heavy rain
                        71: '🌨️', // Slight snow
                        73: '🌨️', // Moderate snow
                        75: '❄️', // Heavy snow
                        80: '🌦️', // Slight rain showers
                        81: '🌧️', // Moderate rain showers
                        82: '⛈️', // Violent rain showers
                        95: '⛈️', // Thunderstorm
                        96: '⛈️', // Thunderstorm with hail
                        99: '⛈️'  // Thunderstorm with heavy hail
                    };
                    
                    const icon = weatherIcons[weatherCode] || '🌤️';
                    document.getElementById('weatherIcon').textContent = icon;
                }
            } catch (error) {
                console.error('Weather API error:', error);
                // Fallback to default display
                document.getElementById('weatherTemp').textContent = '30°C';
                document.getElementById('weatherIcon').textContent = '🌤️';
            }
        }
        
        // Hero Background Rotation - Daily Random
        function setHeroBackground() {
            const heroImages = ['hero-1.jpg', 'hero-2.jpg', 'hero-3.jpg', 'hero-4.jpg', 'hero-5.jpg', 'hero-6.jpg'];
            const today = new Date();
            // Use day of year for daily rotation (same image all day, changes at midnight)
            const start = new Date(today.getFullYear(), 0, 0);
            const diff = today - start;
            const oneDay = 1000 * 60 * 60 * 24;
            const dayOfYear = Math.floor(diff / oneDay);
            // Select image based on day of year (rotates through 6 images)
            const imageIndex = dayOfYear % heroImages.length;
            const selectedImage = heroImages[imageIndex];
            document.querySelector('.hero-bg').style.backgroundImage = `url('${selectedImage}')`;
            console.log(`Hero background: ${selectedImage} (Day ${dayOfYear})`);
        }
        
        // Current room type for booking modal
        let currentBookingRoomType = null;
        
        // Check if date is a Thai holiday
        function isHoliday(dateStr) {
            return holidays.includes(dateStr);
        }
        
        // Check if date is weekend (Fri-Sun)
        function isWeekend(dateObj) {
            const day = dateObj.getDay();
            return day === 5 || day === 6 || day === 0; // Fri=5, Sat=6, Sun=0
        }
        
        // Get season for a given date
        function getSeason(dateObj) {
            const month = dateObj.getMonth() + 1; // 1-12
            // Green Season: Mar-Sep (3-9), High Season: Oct-Feb (10-2)
            if (month >= 3 && month <= 9) {
                return 'green';
            } else {
                return 'high';
            }
        }
        
        // Get price for room type and date
        function getPriceForDate(roomType, dateObj) {
            const dateStr = dateObj.toISOString().split('T')[0];
            const season = getSeason(dateObj);
            const isWeekendDay = isWeekend(dateObj) || isHoliday(dateStr);
            const rateType = isWeekendDay ? 'weekend' : 'weekday';
            return pricing[roomType][season][rateType];
        }
        
        // Calculate booking price
        function calculateBookingPrice() {
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            
            if (!checkIn || !checkOut) return;
            
            const checkInDate = new Date(checkIn);
            const checkOutDate = new Date(checkOut);
            const nights = Math.ceil((checkOutDate - checkInDate) / (1000 * 60 * 60 * 24));
            
            if (nights <= 0) {
                document.getElementById('pricePerNight').textContent = '฿--';
                document.getElementById('numNights').textContent = '-- คืน';
                document.getElementById('totalPrice').textContent = '฿--';
                return;
            }
            
            // Calculate total price based on each night's rate
            let totalPrice = 0;
            let firstNightPrice = 0;
            for (let i = 0; i < nights; i++) {
                const nightDate = new Date(checkInDate);
                nightDate.setDate(nightDate.getDate() + i);
                const price = getPriceForDate(currentBookingRoomType, nightDate);
                totalPrice += price;
                if (i === 0) firstNightPrice = price;
            }
            
            document.getElementById('pricePerNight').textContent = `฿${firstNightPrice.toLocaleString()}`;
            document.getElementById('numNights').textContent = `${nights} คืน`;
            document.getElementById('totalPrice').textContent = `฿${totalPrice.toLocaleString()}`;
        }
        
        // Open booking modal
        function openBookingModal(roomType) {
            currentBookingRoomType = roomType;
            const modal = document.getElementById('bookingModal');
            const roomNames = { hytte: '🏠 Hytte', hus: '🏡 Hus' };
            document.getElementById('modalRoomName').textContent = `📝 จอง ${roomNames[roomType]}`;
            
            // Set minimum date to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('checkInDate').min = today;
            document.getElementById('checkOutDate').min = today;
            
            // Set default dates (today and tomorrow)
            const tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            document.getElementById('checkInDate').value = today;
            document.getElementById('checkOutDate').value = tomorrow.toISOString().split('T')[0];
            
            modal.classList.add('active');
            calculateBookingPrice();
        }
        
        // Close booking modal
        function closeBookingModal() {
            document.getElementById('bookingModal').classList.remove('active');
        }
        
        // Submit booking
        function submitBooking() {
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            const guests = document.getElementById('guestCount').value;
            
            if (!checkIn || !checkOut) {
                alert('กรุณาเลือกวันที่เช็คอินและเช็คเอาท์');
                return;
            }
            
            // Here you would typically send the booking to a server
            // For now, we'll just show a success message
            alert(`✅ จอง ${currentBookingRoomType === 'hytte' ? 'Hytte' : 'Hus'} สำเร็จ!\nเช็คอิน: ${checkIn}\nเช็คเอาท์: ${checkOut}\nผู้พัก: ${guests} คน`);
            closeBookingModal();
        }
        
        // Update room availability from localStorage
        function updateRoomAvailability() {
            try {
                const bookings = JSON.parse(localStorage.getItem('vela_bookings') || '[]');
                const today = new Date().toISOString().split('T')[0];
                
                // Count booked rooms for each type
                let hytteBooked = 0;
                let husBooked = 0;
                
                bookings.forEach(booking => {
                    if (booking.checkOut > today) {
                        if (booking.roomType === 'hytte') hytteBooked++;
                        if (booking.roomType === 'hus') husBooked++;
                    }
                });
                
                const hytteAvailable = Math.max(0, 5 - hytteBooked);
                const husAvailable = Math.max(0, 1 - husBooked);
                
                document.getElementById('hytte-available').textContent = hytteAvailable;
                document.getElementById('hus-available').textContent = husAvailable;
            } catch (e) {
                console.error('Error updating availability:', e);
            }
        }
        
        // Room Slideshow Functions
        const slideState = {
            hytte: { current: 0, total: 3 }
        };
        
        function moveSlide(room, direction) {
            const state = slideState[room];
            if (!state) return;
            
            state.current += direction;
            if (state.current < 0) state.current = state.total - 1;
            if (state.current >= state.total) state.current = 0;
            
            updateSlide(room);
        }
        
        function goToSlide(room, index) {
            const state = slideState[room];
            if (!state) return;
            
            state.current = index;
            updateSlide(room);
        }
        
        function updateSlide(room) {
            const state = slideState[room];
            if (!state) return;
            
            const container = document.getElementById(room + '-slides');
            const dots = document.querySelectorAll(`#${room}-dots .slideshow-dot`);
            
            if (container) {
                container.style.transform = `translateX(-${state.current * 100}%)`;
            }
            
            dots.forEach((dot, index) => {
                dot.classList.toggle('active', index === state.current);
            });
        }
        
        // Doi Hua Mot Slideshow Functions (Slow Auto-Rotation)
        const doiSlideState = { current: 0, total: 4 };
        let doiAutoSlide;
        
        function moveDoiSlide(direction) {
            doiSlideState.current += direction;
            if (doiSlideState.current < 0) doiSlideState.current = doiSlideState.total - 1;
            if (doiSlideState.current >= doiSlideState.total) doiSlideState.current = 0;
            updateDoiSlide();
            resetDoiTimer(); // Reset timer on manual navigation
        }
        
        function goToDoiSlide(index) {
            doiSlideState.current = index;
            updateDoiSlide();
            resetDoiTimer(); // Reset timer on manual navigation
        }
        
        function updateDoiSlide() {
            const container = document.getElementById('doiSlides');
            const dots = document.querySelectorAll('#doiDots .doi-dot');
            
            if (container) {
                container.style.transform = `translateX(-${doiSlideState.current * 100}%)`;
            }
            
            dots.forEach((dot, index) => {
                dot.classList.toggle('active', index === doiSlideState.current);
            });
        }
        
        function startDoiTimer() {
            doiAutoSlide = setInterval(() => {
                moveDoiSlide(1);
            }, 5000); // 5 seconds per slide (SLOW rotation)
        }
        
        function resetDoiTimer() {
            clearInterval(doiAutoSlide);
            startDoiTimer();
        }
        
        // Start auto-rotation when page loads
        setTimeout(() => {
            startDoiTimer();
        }, 1000);
        
        // Initialize
        fetchUmphangWeather(); // Load weather data
        setHeroBackground();
        updateRoomAvailability(); // Load room availability from localStorage
        
        window.addEventListener('scroll', () => {
            document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 100);
        });
        
        // Refresh weather every 30 minutes
        setInterval(fetchUmphangWeather, 1800000);
        
        document.addEventListener('keydown', (e) => {
            if (document.getElementById('lightbox').classList.contains('active')) {
                if (e.key === 'Escape') closeLightbox();
                if (e.key === 'ArrowLeft') navigateLightbox(-1);
                if (e.key === 'ArrowRight') navigateLightbox(1);
            }
        });
        
        // ==================== BOOKING SYSTEM ====================
        
        // Current booking state
        let currentBookingType = 'room'; // 'room' or 'tour'
        let selectedRoomType = 'hytte';
        let selectedTours = [];
        
        // Check if date is holiday
        function isHoliday(dateStr) {
            return holidays.includes(dateStr);
        }
        
        // Get season for date
        function getSeason(date) {
            const month = date.getMonth() + 1;
            // High season: October - February
            if (month >= 10 || month <= 2) {
                return 'high';
            }
            // Green season: March - September
            return 'green';
        }
        
        // Check if weekend
        function isWeekend(date) {
            const day = date.getDay();
            return day === 0 || day === 6; // Sunday or Saturday
        }
        
        // Get price for room type and date
        function getPriceForDate(roomType, dateStr) {
            const date = new Date(dateStr);
            const season = getSeason(date);
            const weekend = isWeekend(date) || isHoliday(dateStr);
            const priceType = weekend ? 'weekend' : 'weekday';
            return pricing[roomType][season][priceType];
        }
        
        // Calculate nights between two dates
        function calculateNights(checkIn, checkOut) {
            const start = new Date(checkIn);
            const end = new Date(checkOut);
            const diffTime = end - start;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            return Math.max(0, diffDays);
        }
        
        // Get bookings from localStorage
        function getBookings() {
            const data = localStorage.getItem('vela_bookings');
            return data ? JSON.parse(data) : [];
        }
        
        // Save booking to localStorage
        function saveBooking(booking) {
            const bookings = getBookings();
            bookings.push(booking);
            localStorage.setItem('vela_bookings', JSON.stringify(bookings));
        }
        
        // Get booked rooms for a date range
        function getBookedRooms(roomType, checkIn, checkOut) {
            const bookings = getBookings();
            const checkInDate = new Date(checkIn);
            const checkOutDate = new Date(checkOut);
            let booked = 0;
            
            bookings.forEach(booking => {
                if (booking.type === 'room' && booking.roomType === roomType) {
                    const bookingCheckIn = new Date(booking.checkIn);
                    const bookingCheckOut = new Date(booking.checkOut);
                    
                    // Check for overlap
                    if (checkInDate < bookingCheckOut && checkOutDate > bookingCheckIn) {
                        booked += booking.rooms || 1;
                    }
                }
            });
            
            return booked;
        }
        
        // Get available rooms for a date
        function getAvailableRooms(roomType, dateStr) {
            const totalRooms = roomType === 'hytte' ? 5 : 1;
            const bookings = getBookings();
            const date = new Date(dateStr);
            let booked = 0;
            
            bookings.forEach(booking => {
                if (booking.type === 'room' && booking.roomType === roomType) {
                    const checkIn = new Date(booking.checkIn);
                    const checkOut = new Date(booking.checkOut);
                    
                    // Check if date falls within booking
                    if (date >= checkIn && date < checkOut) {
                        booked += booking.rooms || 1;
                    }
                }
            });
            
            return Math.max(0, totalRooms - booked);
        }
        
        // Update room availability display
        function updateRoomAvailability() {
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            const availabilityEl = document.getElementById('roomAvailability');
            const availabilityList = document.getElementById('availabilityList');
            
            if (!checkIn || !checkOut) {
                availabilityEl.className = 'room-availability';
                availabilityList.innerHTML = 'กรุณาเลือกวันที่เช็คอินและเช็คเอาท์';
                return;
            }
            
            const nights = calculateNights(checkIn, checkOut);
            let html = '';
            let allAvailable = true;
            let someLow = false;
            
            for (let i = 0; i < nights; i++) {
                const date = new Date(checkIn);
                date.setDate(date.getDate() + i);
                const dateStr = date.toISOString().split('T')[0];
                const available = getAvailableRooms(selectedRoomType, dateStr);
                const total = selectedRoomType === 'hytte' ? 5 : 1;
                const dayName = date.toLocaleDateString('th-TH', { weekday: 'short' });
                const dateDisplay = date.toLocaleDateString('th-TH', { day: 'numeric', month: 'short' });
                
                let status = '✅';
                let statusClass = '';
                if (available === 0) {
                    status = '❌';
                    allAvailable = false;
                } else if (available <= 2) {
                    status = '⚠️';
                    someLow = true;
                }
                
                html += `<div>${status} ${dayName} ${dateDisplay}: ${available}/${total} ห้อง</div>`;
            }
            
            availabilityList.innerHTML = html;
            
            if (!allAvailable) {
                availabilityEl.className = 'room-availability none';
                availabilityEl.querySelector('.availability-title').innerHTML = '❌ ห้องเต็มบางวัน';
            } else if (someLow) {
                availabilityEl.className = 'room-availability low';
                availabilityEl.querySelector('.availability-title').innerHTML = '⚠️ ห้องเหลือน้อย';
            } else {
                availabilityEl.className = 'room-availability';
                availabilityEl.querySelector('.availability-title').innerHTML = '✅ ห้องว่าง';
            }
        }
        
        // Calculate room price
        function calculatePrice() {
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            const rooms = parseInt(document.getElementById('bookingRooms').value) || 1;
            
            if (!checkIn || !checkOut) {
                document.getElementById('roomPriceDisplay').style.display = 'none';
                document.getElementById('confirmBookingBtn').disabled = true;
                return;
            }
            
            const nights = calculateNights(checkIn, checkOut);
            if (nights <= 0) {
                document.getElementById('roomPriceDisplay').style.display = 'none';
                document.getElementById('confirmBookingBtn').disabled = true;
                return;
            }
            
            // Calculate total price
            let totalPrice = 0;
            let seasonTypes = new Set();
            
            for (let i = 0; i < nights; i++) {
                const date = new Date(checkIn);
                date.setDate(date.getDate() + i);
                const dateStr = date.toISOString().split('T')[0];
                const price = getPriceForDate(selectedRoomType, dateStr);
                totalPrice += price * rooms;
                
                const season = getSeason(date);
                seasonTypes.add(season === 'high' ? 'High' : 'Green');
            }
            
            // Update display
            const avgPrice = Math.round(totalPrice / nights / rooms);
            document.getElementById('pricePerNight').textContent = `฿${avgPrice.toLocaleString()}`;
            document.getElementById('numberOfNights').textContent = `${nights} คืน`;
            document.getElementById('numberOfRooms').textContent = `${rooms} ห้อง`;
            document.getElementById('seasonType').textContent = Array.from(seasonTypes).join(' + ');
            document.getElementById('totalPrice').textContent = `฿${totalPrice.toLocaleString()}`;
            document.getElementById('roomPriceDisplay').style.display = 'block';
            
            // Update summary
            document.getElementById('summaryItem').textContent = `${selectedRoomType === 'hytte' ? 'Hytte' : 'Hus'} × ${rooms} ห้อง`;
            document.getElementById('summaryDate').textContent = `${new Date(checkIn).toLocaleDateString('th-TH')} - ${new Date(checkOut).toLocaleDateString('th-TH')}`;
            document.getElementById('summaryTotal').textContent = `฿${totalPrice.toLocaleString()}`;
            document.getElementById('bookingSummary').style.display = 'block';
            
            // Enable confirm button
            document.getElementById('confirmBookingBtn').disabled = false;
            
            // Update availability
            updateRoomAvailability();
        }
        
        // Select room type
        function selectRoomType(type) {
            selectedRoomType = type;
            document.querySelectorAll('.booking-type-option').forEach(el => el.classList.remove('selected'));
            document.getElementById(`roomType-${type}`).classList.add('selected');
            
            // Update max rooms
            const maxRooms = type === 'hytte' ? 5 : 1;
            const roomsInput = document.getElementById('bookingRooms');
            roomsInput.max = maxRooms;
            if (parseInt(roomsInput.value) > maxRooms) {
                roomsInput.value = maxRooms;
            }
            
            calculatePrice();
        }
        
        // Select tour
        function selectTour(tourId, price1, price2) {
            const checkbox = document.getElementById(`chk-${tourId}`);
            checkbox.checked = !checkbox.checked;
            
            const optionEl = document.getElementById(`tour-${tourId}`);
            if (checkbox.checked) {
                optionEl.classList.add('selected');
                if (!selectedTours.find(t => t.id === tourId)) {
                    selectedTours.push({ id: tourId, price1, price2 });
                }
            } else {
                optionEl.classList.remove('selected');
                selectedTours = selectedTours.filter(t => t.id !== tourId);
            }
            
            calculateTourPrice();
        }
        
        // Calculate tour price
        function calculateTourPrice() {
            const people = parseInt(document.getElementById('tourPeople').value) || 1;
            let totalPrice = 0;
            
            selectedTours.forEach(tour => {
                if (tour.id === 'vip-thailosu') {
                    totalPrice += people <= 6 ? tour.price1 : tour.price2;
                } else if (tour.id === '4x4-onsen') {
                    totalPrice += people <= 5 ? tour.price1 : tour.price2;
                } else {
                    totalPrice += tour.price1; // Fixed price for others
                }
            });
            
            if (totalPrice > 0) {
                document.getElementById('tourTotalPrice').textContent = `฿${totalPrice.toLocaleString()}`;
                document.getElementById('tourPriceDisplay').style.display = 'block';
                document.getElementById('summaryItem').textContent = `${selectedTours.length} ทัวร์`;
                document.getElementById('summaryDate').textContent = document.getElementById('tourDate').value || '-';
                document.getElementById('summaryTotal').textContent = `฿${totalPrice.toLocaleString()}`;
                document.getElementById('bookingSummary').style.display = 'block';
                document.getElementById('confirmBookingBtn').disabled = false;
            } else {
                document.getElementById('tourPriceDisplay').style.display = 'none';
                document.getElementById('bookingSummary').style.display = 'none';
                document.getElementById('confirmBookingBtn').disabled = true;
            }
        }
        
        // Switch modal tab
        function switchModalTab(tab) {
            currentBookingType = tab;
            document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.modal-content').forEach(c => c.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(`${tab}BookingContent`).classList.add('active');
            
            // Update modal title
            document.getElementById('modalTitle').textContent = tab === 'room' ? '📅 จองห้องพัก' : '🗺️ จองทัวร์';
            
            // Reset summary
            document.getElementById('bookingSummary').style.display = 'none';
            document.getElementById('confirmBookingBtn').disabled = true;
            
            // Set min date for tour
            if (tab === 'tour') {
                const today = new Date().toISOString().split('T')[0];
                document.getElementById('tourDate').min = today;
            }
        }
        
        // Open booking modal
        function openBookingModal(type = 'room', roomType = 'hytte', tourId = null) {
            const modal = document.getElementById('bookingModal');
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
            
            // Set default dates
            const today = new Date();
            const tomorrow = new Date(today);
            tomorrow.setDate(tomorrow.getDate() + 1);
            
            document.getElementById('checkInDate').value = today.toISOString().split('T')[0];
            document.getElementById('checkOutDate').value = tomorrow.toISOString().split('T')[0];
            document.getElementById('tourDate').min = today.toISOString().split('T')[0];
            document.getElementById('tourDate').value = today.toISOString().split('T')[0];
            
            // Switch to appropriate tab
            if (type === 'tour' && tourId) {
                switchModalTab('tour');
                // Auto-select the tour
                const tourMap = {
                    'vip-thailosu': ['vip-thailosu', 5800, 8300],
                    'vip-thailosu-kota': ['vip-thailosu-kota', 8300, 8300],
                    '4x4-thailosu': ['4x4-thailosu', 2500, 2500],
                    '4x4-onsen': ['4x4-onsen', 1850, 2500]
                };
                if (tourMap[tourId]) {
                    const [id, p1, p2] = tourMap[tourId];
                    if (!document.getElementById(`chk-${id}`).checked) {
                        selectTour(id, p1, p2);
                    }
                }
            } else {
                switchModalTab('room');
                if (roomType) {
                    selectRoomType(roomType);
                }
            }
            
            // Clear form fields
            document.getElementById('bookingName').value = '';
            document.getElementById('bookingPhone').value = '';
            document.getElementById('bookingEmail').value = '';
            document.getElementById('bookingRooms').value = '1';
            document.getElementById('tourBookingName').value = '';
            document.getElementById('tourBookingPhone').value = '';
            document.getElementById('tourBookingEmail').value = '';
            document.getElementById('tourPeople').value = '1';
            
            // Reset price display
            document.getElementById('roomPriceDisplay').style.display = 'none';
            document.getElementById('tourPriceDisplay').style.display = 'none';
            document.getElementById('bookingSummary').style.display = 'none';
            document.getElementById('confirmBookingBtn').disabled = true;
            
            updateRoomAvailability();
        }
        
        // Close booking modal
        function closeBookingModal(e) {
            if (e && e.target !== e.currentTarget) return;
            document.getElementById('bookingModal').classList.remove('active');
            document.body.style.overflow = 'auto';
        }
        
        // Confirm booking
        function confirmBooking() {
            if (currentBookingType === 'room') {
                confirmRoomBooking();
            } else {
                confirmTourBooking();
            }
        }
        
        // Confirm room booking
        function confirmRoomBooking() {
            const name = document.getElementById('bookingName').value.trim();
            const phone = document.getElementById('bookingPhone').value.trim();
            const email = document.getElementById('bookingEmail').value.trim();
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            const rooms = parseInt(document.getElementById('bookingRooms').value);
            
            if (!name || !phone) {
                alert('กรุณากรอกชื่อและเบอร์โทรศัพท์');
                return;
            }
            
            const nights = calculateNights(checkIn, checkOut);
            if (nights <= 0) {
                alert('กรุณาเลือกวันที่ถูกต้อง');
                return;
            }
            
            // Check availability
            for (let i = 0; i < nights; i++) {
                const date = new Date(checkIn);
                date.setDate(date.getDate() + i);
                const dateStr = date.toISOString().split('T')[0];
                const available = getAvailableRooms(selectedRoomType, dateStr);
                if (available < rooms) {
                    alert(`❌ ห้องไม่เพียงพอในวันที่ ${new Date(dateStr).toLocaleDateString('th-TH')}`);
                    return;
                }
            }
            
            // Calculate total price
            let totalPrice = 0;
            for (let i = 0; i < nights; i++) {
                const date = new Date(checkIn);
                date.setDate(date.getDate() + i);
                const dateStr = date.toISOString().split('T')[0];
                totalPrice += getPriceForDate(selectedRoomType, dateStr) * rooms;
            }
            
            // Save booking
            const booking = {
                id: Date.now(),
                type: 'room',
                roomType: selectedRoomType,
                name,
                phone,
                email,
                checkIn,
                checkOut,
                rooms,
                totalPrice,
                createdAt: new Date().toISOString()
            };
            
            saveBooking(booking);
            
            alert(`✅ จองห้องพักสำเร็จ!\n\n${selectedRoomType === 'hytte' ? 'Hytte' : 'Hus'} × ${rooms} ห้อง\n${new Date(checkIn).toLocaleDateString('th-TH')} - ${new Date(checkOut).toLocaleDateString('th-TH')}\nรวม: ฿${totalPrice.toLocaleString()}\n\nเจ้าหน้าที่จะติดต่อกลับเพื่อยืนยันการจอง`);
            
            closeBookingModal();
        }
        
        // Confirm tour booking
        function confirmTourBooking() {
            const name = document.getElementById('tourBookingName').value.trim();
            const phone = document.getElementById('tourBookingPhone').value.trim();
            const email = document.getElementById('tourBookingEmail').value.trim();
            const tourDate = document.getElementById('tourDate').value;
            const people = parseInt(document.getElementById('tourPeople').value);
            
            if (!name || !phone) {
                alert('กรุณากรอกชื่อและเบอร์โทรศัพท์');
                return;
            }
            
            if (selectedTours.length === 0) {
                alert('กรุณาเลือกทัวร์');
                return;
            }
            
            // Calculate total price
            let totalPrice = 0;
            const tourNames = [];
            
            selectedTours.forEach(tour => {
                let price;
                if (tour.id === 'vip-thailosu') {
                    price = people <= 6 ? tour.price1 : tour.price2;
                    tourNames.push('VIP ทีลอซู 1 วัน');
                } else if (tour.id === 'vip-thailosu-kota') {
                    price = tour.price2;
                    tourNames.push('VIP ทีลอซู-โคทะ 1 วัน');
                } else if (tour.id === '4x4-thailosu') {
                    price = tour.price1;
                    tourNames.push('รถ 4x4 ทีลอซู');
                } else if (tour.id === '4x4-onsen') {
                    price = people <= 5 ? tour.price1 : tour.price2;
                    tourNames.push('รถ 4x4 ออนเซ็น');
                }
                totalPrice += price;
            });
            
            // Save booking
            const booking = {
                id: Date.now(),
                type: 'tour',
                tours: selectedTours.map(t => t.id),
                tourNames,
                name,
                phone,
                email,
                tourDate,
                people,
                totalPrice,
                createdAt: new Date().toISOString()
            };
            
            saveBooking(booking);
            
            alert(`✅ จองทัวร์สำเร็จ!\n\n${tourNames.join(', ')}\nวันที่: ${new Date(tourDate).toLocaleDateString('th-TH')}\nจำนวน: ${people} คน\nรวม: ฿${totalPrice.toLocaleString()}\n\nเจ้าหน้าที่จะติดต่อกลับเพื่อยืนยันการจอง`);
            
            closeBookingModal();
        }
        
        // Update booking buttons in room cards
        function initBookingButtons() {
            // Add booking buttons to room cards
            const roomCards = document.querySelectorAll('.room-card');
            roomCards.forEach((card, index) => {
                const roomType = index === 0 ? 'hytte' : 'hus';
                const existingBtn = card.querySelector('.book-room-btn');
                if (!existingBtn) {
                    const bookBtn = document.createElement('button');
                    bookBtn.className = 'btn btn-primary book-room-btn';
                    bookBtn.style.cssText = 'width: 100%; margin-top: 1rem;';
                    bookBtn.textContent = '📅 จองตอนนี้';
                    bookBtn.onclick = () => openBookingModal('room', roomType);
                    card.querySelector('.room-content').appendChild(bookBtn);
                }
            });
            
            // Add booking buttons to tour cards
            const tourCards = document.querySelectorAll('.tour-card');
            const tourMap = ['vip-thailosu', 'vip-thailosu-kota', '4x4-thailosu', '4x4-onsen'];
            tourCards.forEach((card, index) => {
                const tourId = tourMap[index];
                const existingBtn = card.querySelector('.book-tour-btn');
                if (!existingBtn && tourId) {
                    const bookBtn = document.createElement('button');
                    bookBtn.className = 'btn btn-primary book-tour-btn';
                    bookBtn.style.cssText = 'width: 100%; margin-top: 1rem;';
                    bookBtn.textContent = '📅 จองทัวร์นี้';
                    bookBtn.onclick = () => openBookingModal('tour', null, tourId);
                    card.appendChild(bookBtn);
                }
            });
            
            // Update hero CTA button
            const heroCtaBtn = document.querySelector('.hero-cta .btn-primary');
            if (heroCtaBtn) {
                heroCtaBtn.onclick = () => openBookingModal('room', 'hytte');
            }
        }
        
        // Initialize booking system
        initBookingButtons();
        
        // ===== TOUR BOOKING FUNCTIONS =====
        
        // Tour Pricing Configuration
        const tourPricing = {
            1: { name: 'VIP ทีลอซู 1 วัน', base: 5800, baseMax: 6, high: 8300 },
            2: { name: 'VIP ทีลอซู-โคทะ 1 วัน', base: 8300, baseMax: 10, high: 8300 },
            3: { name: 'รถ 4x4 ทีลอซู', base: 2500, baseMax: 10, high: 2500 },
            4: { name: 'รถ 4x4 ออนเซ็น', base: 1850, baseMax: 5, high: 2500 },
            5: { name: 'ดอยหัวหมด', base: 1000, baseMax: 5, high: 1500 }
        };
        
        // Update Tour Price based on number of people
        function updateTourPrice(tourId) {
            const peopleSelect = document.getElementById(`tour${tourId}-people`);
            if (!peopleSelect) return;
            
            const people = parseInt(peopleSelect.value);
            const pricing = tourPricing[tourId];
            
            let price;
            if (people <= pricing.baseMax) {
                price = pricing.base;
            } else {
                price = pricing.high;
            }
            
            // Update total price display
            const totalEl = document.getElementById(`tour${tourId}-total`);
            if (totalEl) {
                totalEl.innerHTML = `
                    <span style="font-size: 0.85rem; color: var(--dark-gray);">ราคารวม: </span>
                    <span style="font-size: 1.3rem; font-weight: 800; color: var(--charcoal);">฿${price.toLocaleString()}</span>
                `;
            }
            
            return price;
        }
        
        // Open Booking Modal for Tour
        function openBookingModal(tourId) {
            const pricing = tourPricing[tourId];
            const peopleSelect = document.getElementById(`tour${tourId}-people`);
            const people = peopleSelect ? parseInt(peopleSelect.value) : 1;
            const price = updateTourPrice(tourId);
            
            // Set modal values
            document.getElementById('bookingTourId').value = tourId;
            document.getElementById('modalTourName').textContent = pricing.name;
            document.getElementById('bookingTourName').value = pricing.name;
            document.getElementById('bookingPeople').value = people;
            document.getElementById('bookingTotalPrice').textContent = `฿${price.toLocaleString()}`;
            
            // Set minimum date to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('bookingDate').setAttribute('min', today);
            
            // Show modal
            document.getElementById('bookingModal').style.display = 'flex';
        }
        
        // Close Booking Modal
        function closeBookingModal() {
            document.getElementById('bookingModal').style.display = 'none';
            document.getElementById('bookingForm').reset();
        }
        
        // Submit Tour Booking
        function submitBooking(event) {
            event.preventDefault();
            
            const tourId = document.getElementById('bookingTourId').value;
            const name = document.getElementById('bookingName').value;
            const phone = document.getElementById('bookingPhone').value;
            const date = document.getElementById('bookingDate').value;
            const people = document.getElementById('bookingPeople').value;
            const tourName = document.getElementById('bookingTourName').value;
            const totalPrice = document.getElementById('bookingTotalPrice').textContent;
            
            // Create booking object
            const booking = {
                id: Date.now(),
                tourId: parseInt(tourId),
                tourName: tourName,
                name: name,
                phone: phone,
                date: date,
                people: parseInt(people),
                totalPrice: totalPrice,
                bookedAt: new Date().toISOString()
            };
            
            // Save to localStorage
            let bookings = JSON.parse(localStorage.getItem('velaBookings') || '[]');
            bookings.push(booking);
            localStorage.setItem('velaBookings', JSON.stringify(bookings));
            
            // Show success message
            alert(`✅ จองทัวร์สำเร็จ!\n\n${tourName}\nชื่อ: ${name}\nเบอร์: ${phone}\nวันที่: ${date}\nจำนวน: ${people} คน\n${totalPrice}\n\nขอบคุณที่ใช้บริการ!`);
            
            // Close modal
            closeBookingModal();
        }
        
        // Close modal when clicking outside
        const bookingModalEl = document.getElementById('bookingModal');
        if (bookingModalEl) {
            bookingModalEl.addEventListener('click', function(e) {
                if (e.target === this) {
                    closeBookingModal();
                }
            });
        }
        
        // Initialize tour prices on page load
        for (let i = 1; i <= 5; i++) {
            updateTourPrice(i);
        }
    </script>
</body>
</html>
