                    <label style="font-size: 0.85rem; color: var(--dark-gray); font-weight: 600;">จำนวนคน</label>
                    <select id="tour5-people" onchange="updateTourPrice(5)" style="width: 100%; padding: 0.75rem; border: 2px solid var(--light-gray); border-radius: 10px; font-size: 0.95rem;">
                        <option value="1">1 คน</option>
