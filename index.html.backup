        <!-- Doi Hua Mot Slideshow Section -->
        <div class="doi-section" style="margin-top: 4rem; background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);">
            <div class="doi-container">
                <div class="doi-header">
                    <h2 class="doi-title">🏔️ ดอยหัวหมด</h2>
                    <p class="doi-subtitle">ชมวิวทะเลหมอกที่สวยงามที่สุดในอุ้มผาง</p>
                </div>
                
                <div class="doi-slideshow" id="doiSlideshow">
                    <div class="doi-slides" id="doiSlides">
                        <div class="doi-slide"><img src="doihua-1.jpg" alt="Doi Hua Mot 1" onerror="this.parentElement.innerHTML='[ดอยหัวหมด 1]';"></div>
                        <div class="doi-slide"><img src="doihua-2.jpg" alt="Doi Hua Mot 2" onerror="this.parentElement.innerHTML='[ดอยหัวหมด 2]';"></div>
                        <div class="doi-slide"><img src="doihua-3.jpg" alt="Doi Hua Mot 3" onerror="this.parentElement.innerHTML='[ดอยหัวหมด 3]';"></div>
                        <div class="doi-slide"><img src="doihua-4.jpg" alt="Doi Hua Mot 4" onerror="this.parentElement.innerHTML='[ดอยหัวหมด 4]';"></div>
                    </div>
                    <div class="doi-nav">
                        <button class="doi-btn" onclick="moveDoiSlide(-1)">‹</button>
                        <button class="doi-btn" onclick="moveDoiSlide(1)">›</button>
                    </div>
                    <div class="doi-dots" id="doiDots">
                        <div class="doi-dot active" onclick="goToDoiSlide(0)"></div>
                        <div class="doi-dot" onclick="goToDoiSlide(1)"></div>
                        <div class="doi-dot" onclick="goToDoiSlide(2)"></div>
                        <div class="doi-dot" onclick="goToDoiSlide(3)"></div>
                    </div>
                </div>
                
                <div class="doi-packages">
                    <div class="doi-package">
                        <div class="doi-package-icon">🎁</div>
                        <h3 class="doi-package-name">เดินง่าย</h3>
                        <p class="doi-package-desc">เส้นทางเดินสบาย เหมาะสำหรับทุกคน</p>
                        <div class="doi-package-price">แถมฟรีในทัวร์</div>
                        <p class="doi-package-note">✅ ไม่เสียค่าใช้จ่ายเพิ่ม</p>
                    </div>
                    <div class="doi-package">
                        <div class="doi-package-icon">🏔️</div>
                        <h3 class="doi-package-name">ขึ้นยอดดอย</h3>
                        <p class="doi-package-desc">พิชิตยอดดอยหัวหมด วิวทะเลหมอก</p>
                        <div class="doi-package-price">฿1,000 <span>/กรุ๊ป (1-5 คน)</span></div>
                        <p class="doi-package-note">💰 6-10 คน: ฿1,500</p>
                    </div>
                </div>
                

            </div>
        </div>
    </section>
    
    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
        <button class="lightbox-close" onclick="closeLightbox()">×</button>
        <button class="lightbox-nav lightbox-prev" onclick="navigateLightbox(-1)">‹</button>
        <button class="lightbox-nav lightbox-next" onclick="navigateLightbox(1)">›</button>
        <div class="lightbox-content" id="lightboxContent"></div>
    </div>
    
    <!-- Tours Section -->
    <section class="tours-detail" id="tours">
        <div class="section-header">
            <h2 class="section-title">ทัวร์อุ้มผาง</h2>
            <p class="section-subtitle">เลือกทัวร์ได้ตอนจองห้องพัก หรือจองแยกก็ได้</p>
        </div>
        <div class="tours-grid">
            <!-- Tour 1: VIP ทีลอซู 1 วัน -->
            <div class="tour-card vip">
                <span class="tour-card-badge">VIP</span>
                <img src="waterfall.jpg" alt="น้ำตกทีลอซู" style="width: 100%; height: auto; max-height: 300px; object-fit: contain; border-radius: 12px; margin-bottom: 1rem;" onerror="this.style.display='none';">
                <h4 class="tour-card-title">🏆 VIP ทีลอซู 1 วัน</h4>
                <p class="tour-card-route">รถส่วนตัว + ไกด์ + อาหารกลางวัน</p>
                <div class="tour-card-price" id="tour1-price">฿5,800 <span>/กลุ่ม (1-6 คน)</span></div>
                <p style="font-size: 0.85rem; color: var(--gray); margin-top: 0.5rem;">7-10 คน: ฿8,300</p>
                <div class="form-group" style="margin-top: 1rem;">
                    <label style="font-size: 0.85rem; color: var(--dark-gray); font-weight: 600;">จำนวนคน</label>
                    <select id="tour1-people" onchange="updateTourPrice(1)" style="width: 100%; padding: 0.75rem; border: 2px solid var(--light-gray); border-radius: 10px; font-size: 0.95rem;">
                        <option value="1">1 คน</option>
                        <option value="2">2 คน</option>
                        <option value="3">3 คน</option>
                        <option value="4">4 คน</option>
                        <option value="5">5 คน</option>
                        <option value="6" selected>6 คน</option>
                        <option value="7">7 คน</option>
                        <option value="8">8 คน</option>
                        <option value="9">9 คน</option>
                        <option value="10">10 คน</option>
                    </select>
                </div>
                <div class="tour-total-price" id="tour1-total" style="margin-top: 0.75rem; padding: 0.75rem; background: var(--yellow-light); border-radius: 10px; text-align: center;">
                    <span style="font-size: 0.85rem; color: var(--dark-gray);">ราคารวม: </span>
                    <span style="font-size: 1.3rem; font-weight: 800; color: var(--charcoal);">฿5,800</span>
                </div>
                <button onclick="openBookingModal(1)" class="btn btn-primary" style="width: 100%; margin-top: 1rem; padding: 0.85rem; font-size: 1rem;">📝 จองทัวร์นี้</button>
            </div>
            
