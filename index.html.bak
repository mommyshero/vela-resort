    <script>
        // ==================== LIGHTBOX FUNCTIONS ====================
        function openLightbox(imageSrc, caption) {
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightbox-img');
            const lightboxCaption = document.getElementById('lightbox-caption');

            if (!lightbox || !lightboxImg) {
                console.error('â Lightbox elements not found!');
                return;
            }

            lightboxImg.src = imageSrc;
            if (lightboxCaption) lightboxCaption.textContent = caption;
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
            
            console.log('â Lightbox opened:', imageSrc);
        }

        function closeLightbox(event) {
            if (event.target.id === 'lightbox' || event.target.classList.contains('lightbox-close')) {
                const lightbox = document.getElementById('lightbox');
                lightbox.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        }

        // ==================== EXPAND/COLLAPSE FUNCTIONS ====================
        function toggleWaterfall(sectionId) {
            const content = document.getElementById('content-' + sectionId);
            const btn = document.getElementById('btn-' + sectionId);

            if (content.classList.contains('active')) {
                content.classList.remove('active');
                btn.textContent = 'đ €€';
            } else {
                content.classList.add('active');
                btn.textContent = 'đ ';
            }
        }

        // Close lightbox on ESC key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                const lightbox = document.getElementById('lightbox');
                if (lightbox.classList.contains('active')) {
                    closeLightbox({ target: { classList: { contains: () => true } } });
                }
            }
        });

        // ==================== PRICING CONFIGURATION ====================
        const pricing = {
            hytte: {
                green: { weekday: 750, weekend: 950 },
                high: { weekday: 1250, weekend: 1500 }
            },
            hus: {
                green: { weekday: 1200, weekend: 1800 },
                high: { weekday: 2100, weekend: 2500 }
            }
        };

        // Thai Government Holidays 2024-2026
        const holidays = [
            '2024-01-01', '2024-02-24', '2024-04-06', '2024-04-13', '2024-04-14', '2024-04-15',
            '2024-05-01', '2024-05-04', '2024-05-22', '2024-06-03', '2024-07-20', '2024-07-21',
            '2024-07-28', '2024-08-12', '2024-10-13', '2024-10-23', '2024-12-05', '2024-12-10', '2024-12-31',
            '2025-01-01', '2025-02-12', '2025-04-06', '2025-04-13', '2025-04-14', '2025-04-15',
            '2025-05-01', '2025-05-05', '2025-06-03', '2025-06-11', '2025-07-20', '2025-07-21',
            '2025-07-28', '2025-08-12', '2025-10-13', '2025-10-23', '2025-12-05', '2025-12-10', '2025-12-31',
            '2026-01-01', '2026-02-26', '2026-04-06', '2026-04-13', '2026-04-14', '2026-04-15',
            '2026-05-01', '2026-05-05', '2026-06-03', '2026-06-20', '2026-07-09', '2026-07-10',
            '2026-07-28', '2026-08-12', '2026-10-13', '2026-10-23', '2026-12-05', '2026-12-10', '2026-12-31'
        ];

        // Tour Pricing (Updated with new VIP tours)
        const tourPricing = {
            1: { name: 'VIP  1 ', tiers: [{max: 6, price: 5800}, {max: 10, price: 8300}, {max: 12, price: 10800}, {max: 15, price: 13800}] },
            2: { name: 'VIP - 1 ', tiers: [{max: 6, price: 7500}, {max: 10, price: 10000}, {max: 12, price: 12500}, {max: 15, price: 15500}] },
            3: { name: ' 4x4 ', tiers: [{max: 10, price: 2500}] },
            4: { name: ' 4x4 €', tiers: [{max: 5, price: 1850}, {max: 10, price: 2500}] },
            5: { name: '', tiers: [{max: 5, price: 1000}, {max: 10, price: 1500}] }
        };

        // Current booking state
        let selectedRoomType = 'hytte';
        let currentLightboxIndex = 0;

        // ==================== HELPER FUNCTIONS ====================

        function isHoliday(dateStr) {
            return holidays.includes(dateStr);
        }

        function getSeason(date) {
            const month = date.getMonth() + 1;
            return (month >= 10 || month <= 2) ? 'high' : 'green';
        }

        function isWeekend(date) {
            const day = date.getDay();
            return day === 0 || day === 6;
        }

        function getPriceForDate(roomType, dateStr) {
            const date = new Date(dateStr);
            const season = getSeason(date);
            const weekend = isWeekend(date) || isHoliday(dateStr);
            const priceType = weekend ? 'weekend' : 'weekday';
            return pricing[roomType][season][priceType];
        }

        function calculateNights(checkIn, checkOut) {
            const start = new Date(checkIn);
            const end = new Date(checkOut);
            const diffTime = end - start;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            return Math.max(0, diffDays);
        }

        function getBookings() {
            const data = localStorage.getItem('vela_bookings');
            return data ? JSON.parse(data) : [];
        }

        function saveBooking(booking) {
            const bookings = getBookings();
            bookings.push(booking);
            localStorage.setItem('vela_bookings', JSON.stringify(bookings));
        }

        function getAvailableRooms(roomType, dateStr) {
            const totalRooms = roomType === 'hytte' ? 5 : 1;
            const bookings = getBookings();
            const date = new Date(dateStr);
            let booked = 0;

            bookings.forEach(booking => {
                if (booking.type === 'room' && booking.roomType === roomType) {
                    const checkIn = new Date(booking.checkIn);
                    const checkOut = new Date(booking.checkOut);
                    if (date >= checkIn && date < checkOut) {
                        booked += booking.rooms || 1;
                    }
                }
            });

            return Math.max(0, totalRooms - booked);
        }

        function checkRoomAvailability(roomType, checkIn, checkOut, requestedRooms) {
            const bookings = getBookings();
            const totalRooms = roomType === 'hytte' ? 5 : 1;
            const checkInDate = new Date(checkIn);
            checkInDate.setHours(0, 0, 0, 0);
            const checkOutDate = new Date(checkOut);
            checkOutDate.setHours(0, 0, 0, 0);

            // Check availability for EACH night in the stay period
            let minAvailableRooms = totalRooms;
            const nightlyAvailability = {};

            // Generate all nights in the stay period
            const nights = [];
            const currentNight = new Date(checkInDate);
            while (currentNight < checkOutDate) {
                const nightStr = currentNight.toISOString().split('T')[0];
                nights.push(nightStr);
                currentNight.setDate(currentNight.getDate() + 1);
            }

            // Calculate booked rooms for each night
            nights.forEach(night => {
                let bookedOnThisNight = 0;
                bookings.forEach(booking => {
                    if (booking.type === 'room' && booking.roomType === roomType && booking.status !== 'cancelled') {
                        const bookingCheckIn = new Date(booking.checkIn);
                        bookingCheckIn.setHours(0, 0, 0, 0);
                        const bookingCheckOut = new Date(booking.checkOut);
                        bookingCheckOut.setHours(0, 0, 0, 0);

                        // Check if this booking overlaps with the night
                        if (night >= booking.checkIn && night < booking.checkOut) {
                            bookedOnThisNight += booking.rooms || 1;
                        }
                    }
                });

                const availableOnThisNight = totalRooms - bookedOnThisNight;
                nightlyAvailability[night] = {
                    available: availableOnThisNight,
                    booked: bookedOnThisNight,
                    total: totalRooms
                };

                if (availableOnThisNight < minAvailableRooms) {
                    minAvailableRooms = availableOnThisNight;
                }
            });

            // Check if requested rooms exceed minimum available
            if (requestedRooms > minAvailableRooms) {
                // Find the most constrained night
                const constrainedNight = Object.entries(nightlyAvailability)
                    .find(([night, data]) => data.available === minAvailableRooms);

                const constrainedDate = constrainedNight ? 
                    new Date(constrainedNight[0]).toLocaleDateString('th-TH', { day: 'numeric', month: 'short' }) : '';

                return { 
                    available: false, 
                    availableRooms: minAvailableRooms, 
                    message: `â !  ${constrainedDate} € ${minAvailableRooms}  ${totalRooms} `
                };
            }

            return { 
                available: true, 
                availableRooms: minAvailableRooms,
                nightlyAvailability: nightlyAvailability
            };
        }

        // ==================== CALENDAR RENDERING ====================

        function renderCalendar() {
            const checkInInput = document.getElementById('checkInDate');
            const checkOutInput = document.getElementById('checkOutDate');
            const calendarGrid = document.getElementById('calendarGrid');

            if (!checkInInput.value || !checkOutInput.value) return;

            const checkIn = new Date(checkInInput.value);
            const checkOut = new Date(checkOutInput.value);

            // Show 30 days from check-in
            let html = '';
            html += '<div class="calendar-day-header"></div>';
            html += '<div class="calendar-day-header"></div>';
            html += '<div class="calendar-day-header"></div>';
            html += '<div class="calendar-day-header"></div>';
            html += '<div class="calendar-day-header"></div>';
            html += '<div class="calendar-day-header"></div>';
            html += '<div class="calendar-day-header"></div>';

            const startDate = new Date(checkIn);
            startDate.setDate(startDate.getDate() - startDate.getDay()); // Start from Sunday

            // Get all bookings for real-time calculation
            const bookings = getBookings();
            const totalRooms = selectedRoomType === 'hytte' ? 5 : 1;

            for (let i = 0; i < 35; i++) {
                const currentDate = new Date(startDate);
                currentDate.setDate(currentDate.getDate() + i);
                const dateStr = currentDate.toISOString().split('T')[0];
                const dayNum = currentDate.getDate();
                const monthNum = currentDate.getMonth() + 1;

                let dayClass = 'weekday';
                if (isHoliday(dateStr)) {
                    dayClass = 'holiday';
                } else if (isWeekend(currentDate)) {
                    dayClass = 'weekend';
                }

                // Calculate real-time availability for this specific date
                let bookedOnThisDate = 0;
                bookings.forEach(booking => {
                    if (booking.type === 'room' && booking.roomType === selectedRoomType && booking.status !== 'cancelled') {
                        if (dateStr >= booking.checkIn && dateStr < booking.checkOut) {
                            bookedOnThisDate += booking.rooms || 1;
                        }
                    }
                });

                const available = totalRooms - bookedOnThisDate;
                const isSelected = currentDate >= checkIn && currentDate < checkOut;

                // Add visual indicators for availability
                let availabilityClass = '';
                let availabilityIcon = '';
                if (available === 0) {
                    availabilityClass = ' fully-booked';
                    availabilityIcon = 'â';
                } else if (available <= 2) {
                    availabilityClass = ' low-availability';
                    availabilityIcon = 'âď';
                } else if (available === totalRooms) {
                    availabilityIcon = 'â';
                }

                html += `<div class="calendar-day ${dayClass}${isSelected ? ' selected' : ''}${availabilityClass}" title="${available}/${totalRooms} ">`;
                html += `<span class="date-num">${dayNum}/${monthNum}</span>`;
                html += `<span class="room-count">${availabilityIcon} ${available}/${totalRooms}</span>`;
                html += `</div>`;
            }

            calendarGrid.innerHTML = html;
        }

        // ==================== PRICE CALCULATION ====================

        function calculatePrice() {
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            const rooms = parseInt(document.getElementById('bookingRooms').value) || 1;
            const name = document.getElementById('bookingName').value.trim();
            const phone = document.getElementById('bookingPhone').value.trim();

            if (!checkIn || !checkOut) {
                document.getElementById('roomPriceDisplay').style.display = 'none';
                document.getElementById('confirmBookingBtn').disabled = true;
                return;
            }

            const nights = calculateNights(checkIn, checkOut);
            if (nights <= 0) {
                document.getElementById('roomPriceDisplay').style.display = 'none';
                document.getElementById('confirmBookingBtn').disabled = true;
                return;
            }

            let totalPrice = 0;
            let seasonTypes = new Set();

            for (let i = 0; i < nights; i++) {
                const date = new Date(checkIn);
                date.setDate(date.getDate() + i);
                const dateStr = date.toISOString().split('T')[0];
                const price = getPriceForDate(selectedRoomType, dateStr);
                totalPrice += price * rooms;
                seasonTypes.add(getSeason(date) === 'high' ? 'High' : 'Green');
            }

            window.roomPrice = totalPrice;
            const avgPrice = Math.round(totalPrice / nights / rooms);

            document.getElementById('pricePerNight').textContent = `${avgPrice.toLocaleString()}`;
            document.getElementById('numberOfNights').textContent = `${nights} `;
            document.getElementById('numberOfRooms').textContent = `${rooms} `;
            document.getElementById('seasonType').textContent = Array.from(seasonTypes).join(' + ');
            document.getElementById('roomTotalPrice').textContent = `${totalPrice.toLocaleString()}`;
            document.getElementById('summaryTotal').textContent = `${totalPrice.toLocaleString()}`;
            document.getElementById('roomPriceDisplay').style.display = 'block';
            document.getElementById('summaryItem').textContent = `${selectedRoomType === 'hytte' ? '€' : ''}  ${rooms} `;
            document.getElementById('summaryDate').textContent = `${new Date(checkIn).toLocaleDateString('th-TH')} - ${new Date(checkOut).toLocaleDateString('th-TH')}`;
            document.getElementById('bookingSummary').style.display = 'block';

            const confirmBtn = document.getElementById('confirmBookingBtn');
            const confirmBtnHint = document.getElementById('confirmBtnHint');
            const canConfirm = name.length > 0 && phone.length > 0;
            confirmBtn.disabled = !canConfirm;
            
            // Update hint message
            if (confirmBtnHint) {
                if (canConfirm) {
                    confirmBtnHint.style.display = 'none';
                } else {
                    confirmBtnHint.style.display = 'block';
                    confirmBtnHint.innerHTML = 'âď <strong>€</strong> €';
                }
            }
            
            console.log('đ Can confirm:', canConfirm, 'Name:', name.length, 'Phone:', phone.length);

            updateRoomAvailability();
            renderCalendar();
        }

        function selectRoomType(type) {
            selectedRoomType = type;
            document.querySelectorAll('.room-type-card').forEach(el => el.classList.remove('selected'));
            document.getElementById(`roomType-${type}`).classList.add('selected');

            const maxRooms = type === 'hytte' ? 5 : 1;
            const roomsInput = document.getElementById('bookingRooms');
            roomsInput.max = maxRooms;

            // Update room options
            let options = '';
            for (let i = 1; i <= maxRooms; i++) {
                options += `<option value="${i}">${i} </option>`;
            }
            roomsInput.innerHTML = options;

            calculatePrice();
        }

        function updateRoomAvailability() {
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            const rooms = parseInt(document.getElementById('bookingRooms').value) || 1;
            const availabilityEl = document.getElementById('roomAvailability');
            const availabilityList = document.getElementById('availabilityList');

            if (!checkIn || !checkOut) {
                availabilityEl.className = 'room-availability';
                availabilityList.innerHTML = '€€€€';
                return;
            }

            const result = checkRoomAvailability(selectedRoomType, checkIn, checkOut, rooms);
            const totalRooms = selectedRoomType === 'hytte' ? 5 : 1;

            if (!result.available) {
                availabilityEl.className = 'room-availability none';
                availabilityEl.querySelector('.availability-title').innerHTML = 'â ';
                availabilityList.innerHTML = `€ ${result.availableRooms}  ${totalRooms} <br>`;
            } else if (result.availableRooms <= 2) {
                availabilityEl.className = 'room-availability low';
                availabilityEl.querySelector('.availability-title').innerHTML = 'âď €';
                availabilityList.innerHTML = `€ ${result.availableRooms}  ${totalRooms} <br>€!`;
            } else {
                availabilityEl.className = 'room-availability';
                availabilityEl.querySelector('.availability-title').innerHTML = 'â ';
                availabilityList.innerHTML = ` ${result.availableRooms}  ${totalRooms} `;
            }
        }

        // ==================== MODAL FUNCTIONS ====================

        function openBookingModal(type = 'room', roomType = 'hytte') {
            const modal = document.getElementById('bookingModal');
            if (!modal) {
                alert('âď Modal not found!');
                return;
            }
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';

            console.log('â Booking modal opened for', roomType);

            const today = new Date();
            const tomorrow = new Date(today);
            tomorrow.setDate(tomorrow.getDate() + 1);

            document.getElementById('checkInDate').value = today.toISOString().split('T')[0];
            document.getElementById('checkOutDate').value = tomorrow.toISOString().split('T')[0];
            document.getElementById('bookingName').value = '';
            document.getElementById('bookingPhone').value = '';
            document.getElementById('bookingEmail').value = '';

            selectRoomType(roomType);
            calculatePrice();
        }

        // ==================== TOUR ADD-ON FUNCTIONS ====================

        function toggleTourAddon() {
            const checkbox = document.getElementById('addTourCheckbox');
            const content = document.getElementById('tourAddonContent');
            content.style.display = checkbox.checked ? 'block' : 'none';
            if (!checkbox.checked) {
                window.tourAddonPrice = 0;
                updateTotalWithTour();
            }
        }

        function updateTourAddonPrice() {
            const tourId = document.getElementById('tourSelector').value;
            const people = parseInt(document.getElementById('tourPeopleAddon').value) || 1;

            if (!tourId) {
                document.getElementById('tourAddonPriceDisplay').style.display = 'none';
                document.getElementById('tourTypeSelector').style.display = 'none';
                window.tourAddonPrice = 0;
                updateTotalWithTour();
                return;
            }

            let price = 0;
            let tourName = '';

            // Tour pricing (4 tiers) - Modified for Joytrip
            const tourPrices = {
                '1': { name: 'VIP - 1 ', tiers: [[1,6,7500], [7,10,10000], [11,12,12500], [13,15,15500]] },
                '2': { name: '', joinPrice: 2100 },  // Joytrip only, no private option
                '3': { name: ' 4x4 ', tiers: [[1,6,2500], [7,10,2500], [11,12,2500], [13,15,2500]] },
                '4': { name: ' 4x4 €', tiers: [[1,5,1850], [6,10,2500], [11,12,2500], [13,15,2500]] },
                '5': { name: '', tiers: [[1,5,1000], [6,10,1500], [11,12,1500], [13,15,1500]] }
            };

            const tour = tourPrices[tourId];
            if (tour) {
                tourName = tour.name;
                
                // Check if Joytrip (Tour 2 only)
                if (tourId === '2' && tour.joinPrice) {
                    // Joytrip pricing: 2,100  number of people
                    price = tour.joinPrice * people;
                } else if (tour.tiers) {
                    // Private tour pricing (group rate)
                    for (const [min, max, p] of tour.tiers) {
                        if (people >= min && people <= max) {
                            price = p;
                            break;
                        }
                    }
                }
            }

            window.tourAddonPrice = price;
            document.getElementById('tourAddonPrice').textContent = `${price.toLocaleString()}`;
            document.getElementById('tourAddonPriceDisplay').style.display = 'block';
            updateTotalWithTour();
        }

        function updateTotalWithTour() {
            const roomTotal = window.roomPrice || 0;
            const tourTotal = window.tourAddonPrice || 0;
            const grandTotal = roomTotal + tourTotal;

            document.getElementById('summaryTotal').textContent = `${grandTotal.toLocaleString()}`;

            // Update tour row in summary
            const tourRow = document.getElementById('summaryTourRow');
            const tourId = document.getElementById('tourSelector').value;
            const people = document.getElementById('tourPeopleAddon').value;

            if (tourTotal > 0 && tourId) {
                const tourNames = {
                    '1': 'VIP -',
                    '2': 'VIP ',
                    '3': ' 4x4 ',
                    '4': ' 4x4 €',
                    '5': ''
                };
                document.getElementById('summaryTour').textContent = `${tourNames[tourId]} (${people} )`;
                tourRow.style.display = 'block';
            } else {
                tourRow.style.display = 'none';
            }
        }

        function closeBookingModal(e) {
            if (e && e.target !== e.currentTarget) return;
            document.getElementById('bookingModal').classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        function confirmRoomBooking() {
            const name = document.getElementById('bookingName').value.trim();
            const phone = document.getElementById('bookingPhone').value.trim();
            const email = document.getElementById('bookingEmail').value.trim();
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            const rooms = parseInt(document.getElementById('bookingRooms').value);
            const guests = parseInt(document.getElementById('bookingGuests').value) || 2;

            if (!name || !phone) {
                alert('âď €');
                return;
            }

            const nights = calculateNights(checkIn, checkOut);
            if (nights <= 0) {
                alert('âď €');
                return;
            }

            // Double-check availability in real-time before booking
            const availabilityResult = checkRoomAvailability(selectedRoomType, checkIn, checkOut, rooms);
            if (!availabilityResult.available) {
                alert(`âď ${availabilityResult.message}\n\n€`);
                renderCalendar(); // Refresh calendar to show latest availability
                return;
            }

            // Warn if rooms are running low
            const totalRooms = selectedRoomType === 'hytte' ? 5 : 1;
            if (availabilityResult.availableRooms <= 2 && totalRooms - availabilityResult.availableRooms >= 3) {
                const confirmBooking = confirm(`âď € ${availabilityResult.availableRooms} €\n\n?`);
                if (!confirmBooking) return;
            }

            // Check if tour addon is selected
            const addTour = document.getElementById('addTourCheckbox').checked;
            const tourId = addTour ? document.getElementById('tourSelector').value : null;
            const tourPeople = addTour ? parseInt(document.getElementById('tourPeopleAddon').value) : 0;
            const tourPrice = addTour ? (window.tourAddonPrice || 0) : 0;

            const booking = {
                id: Date.now(),
                type: addTour ? 'combined' : 'room',
                roomType: selectedRoomType,
                name, phone, email,
                checkIn, checkOut,
                rooms, guests,
                roomPrice: window.roomPrice,
                tourId: tourId,
                tourPeople: tourPeople,
                tourPrice: tourPrice,
                totalPrice: (window.roomPrice || 0) + tourPrice,
                createdAt: new Date().toISOString()
            };

            saveBooking(booking);
            
            // Refresh calendar to show updated availability
            renderCalendar();

            let message = `â €!\n\n`;
            message += `: ${selectedRoomType === 'hytte' ? '€' : ''}  ${rooms} \n`;
            message += `€: ${new Date(checkIn).toLocaleDateString('th-TH')}\n`;

            if (addTour && tourId) {
                const tourNames = {
                    '1': 'VIP - 1 ',
                    '2': 'VIP  1 ',
                    '3': ' 4x4 ',
                    '4': ' 4x4 €',
                    '5': ''
                };
                message += `\nđď €:\n`;
                message += `${tourNames[tourId]} (${tourPeople} )\n`;
            }
            message += `€€: ${new Date(checkOut).toLocaleDateString('th-TH')}\n`;
            message += `€: ${guests} \n`;
            message += `\nđ : ${window.roomPrice.toLocaleString()}\n\n€€`;

            alert(message);
            closeBookingModal();
        }

        // ==================== TOUR FUNCTIONS ====================

        // Tour booking type state (private or join)
        const tourBookingTypes = {
            1: 'private',  // Tour 1 default: private
            2: 'private',  // Tour 2 default: private
            3: 'private',  // Tour 3 default: private
            4: 'private',  // Tour 4 default: private
            5: 'private'   // Tour 5 default: private
        };

        function selectBookingType(tourId, type) {
            // Update state
            tourBookingTypes[tourId] = type;

            // Update UI
            const privateOption = document.getElementById(`tour${tourId}-private`);
            const joinOption = document.getElementById(`tour${tourId}-join`);
            const priceEl = document.getElementById(`tour${tourId}-price`);
            const totalEl = document.getElementById(`tour${tourId}-total`);

            if (type === 'private') {
                // Private selected
                if (privateOption) {
                    privateOption.style.border = '2px solid #FFD700';
                    privateOption.style.background = '#FEF3C7';
                }
                if (joinOption) {
                    joinOption.style.border = '2px solid #E5E7EB';
                    joinOption.style.background = '#FFFFFF';
                }
                // Show group pricing
                if (tourId === 1 && priceEl) {
                    priceEl.innerHTML = '5,800 <span>/ (1-6 )</span>';
                } else if (tourId === 2 && priceEl) {
                    priceEl.innerHTML = '7,500 <span>/ (1-6 )</span>';
                }
                updateTourPrice(tourId);
            } else {
                // Join trip selected
                if (privateOption) {
                    privateOption.style.border = '2px solid #E5E7EB';
                    privateOption.style.background = '#FFFFFF';
                }
                if (joinOption) {
                    joinOption.style.border = '2px solid #FFD700';
                    joinOption.style.background = '#FEF3C7';
                }
                // Show per-person pricing
                if (tourId === 1 && priceEl) {
                    priceEl.innerHTML = '2,100 <span>/</span>';
                } else if (tourId === 2 && priceEl) {
                    priceEl.innerHTML = '2,100 <span>/</span>';
                }
                // Update total
                if (totalEl) {
                    const people = parseInt(document.getElementById(`tour${tourId}-people`).value);
                    const total = people * 2100;
                    totalEl.innerHTML = `<span style="font-size: 0.85rem; color: var(--dark-gray);">: </span><span style="font-size: 1.3rem; font-weight: 800; color: var(--charcoal);">${total.toLocaleString()}</span>`;
                }
            }
        }

        function updateTourPrice(tourId) {
            const peopleSelect = document.getElementById(`tour${tourId}-people`);
            if (!peopleSelect) return 0;

            const people = parseInt(peopleSelect.value);
            const pricing = tourPricing[tourId];

            let price = pricing.tiers[pricing.tiers.length - 1].price;
            for (const tier of pricing.tiers) {
                if (people <= tier.max) {
                    price = tier.price;
                    break;
                }
            }

            const totalEl = document.getElementById(`tour${tourId}-total`);
            if (totalEl) {
                totalEl.innerHTML = `<span style="font-size: 0.85rem; color: var(--dark-gray);">: </span><span style="font-size: 1.3rem; font-weight: 800; color: var(--charcoal);">${price.toLocaleString()}</span>`;
            }

            return price;
        }

        function openTourBookingModal(tourId) {
            const pricing = tourPricing[tourId];
            const peopleSelect = document.getElementById(`tour${tourId}-people`);
            const people = peopleSelect ? parseInt(peopleSelect.value) : 1;
            const price = updateTourPrice(tourId);

            document.getElementById('bookingTourId').value = tourId;
            document.getElementById('tourBookingTourName').value = pricing.name;
            document.getElementById('tourBookingPeople').value = people;
            document.getElementById('bookingTotalPrice').textContent = `${price.toLocaleString()}`;

            const today = new Date().toISOString().split('T')[0];
            document.getElementById('tourBookingDate').setAttribute('min', today);

            document.getElementById('tourBookingModal').style.display = 'flex';
        }

        function closeTourBookingModal() {
            document.getElementById('tourBookingModal').style.display = 'none';
            document.getElementById('tourBookingForm').reset();
        }

        function updateTourBookingPrice() {
            const tourId = parseInt(document.getElementById('bookingTourId').value);
            const people = parseInt(document.getElementById('tourBookingPeople').value);
            const pricing = tourPricing[tourId];

            let price = pricing.tiers[pricing.tiers.length - 1].price;
            for (const tier of pricing.tiers) {
                if (people <= tier.max) {
                    price = tier.price;
                    break;
                }
            }

            document.getElementById('bookingTotalPrice').textContent = `${price.toLocaleString()}`;
        }

        function submitTourBooking(event) {
            event.preventDefault();

            const tourId = parseInt(document.getElementById('bookingTourId').value);
            const name = document.getElementById('tourBookingName').value;
            const phone = document.getElementById('tourBookingPhone').value;
            const date = document.getElementById('tourBookingDate').value;
            const people = parseInt(document.getElementById('tourBookingPeople').value);
            const tourName = document.getElementById('tourBookingTourName').value;
            const totalPrice = document.getElementById('bookingTotalPrice').textContent;

            const booking = {
                id: Date.now(),
                type: 'tour',
                tourId, tourName,
                name, phone, date, people,
                totalPrice,
                bookedAt: new Date().toISOString()
            };

            saveBooking(booking);

            alert(`â €!\n\n${tourName}\n: ${name}\n€: ${phone}\n: ${date}\n: ${people} \n${totalPrice}\n\n!`);
            closeTourBookingModal();
        }

        // ==================== TOUR POPUP ====================

        function showTourPopup(tourId) {
            const tour = tourPricing[tourId];
            if (!tour) return;

            document.getElementById('popupTourName').textContent = tour.name;

            // Update price table based on tiers
            let tableHtml = '';
            for (let i = 0; i < tour.tiers.length; i++) {
                const tier = tour.tiers[i];
                const prevMax = i > 0 ? tour.tiers[i-1].max + 1 : 1;
                tableHtml += `<tr><td>${prevMax}-${tier.max} </td><td>${tier.price.toLocaleString()}</td></tr>`;
            }

            const popup = document.getElementById('tourDetailPopup');
            popup.querySelector('.tour-price-table tbody').innerHTML = tableHtml;
            popup.style.display = 'flex';
        }

        function closeTourPopup() {
            document.getElementById('tourDetailPopup').style.display = 'none';
        }

        function toggleTourItinerary(tourId) {
            const modal = document.getElementById(`tourItineraryModal${tourId}`);
            if (modal) {
                modal.style.display = modal.style.display === 'none' ? 'flex' : 'none';
            }
        }

        // ==================== GALLERY FUNCTIONS ====================

        function filterGallery(type) {
            document.querySelectorAll('.gallery-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            document.querySelectorAll('.gallery-item').forEach(item => {
                if (type === 'all') {
                    item.style.display = 'block';
                } else {
                    item.style.display = (item.dataset.type === type) ? 'block' : 'none';
                }
            });
        }

        // Global gallery state (already declared above)
        // let currentLightboxIndex = -1;
        // let galleryImages = [];

        function openLightbox(imageSrc, caption) {
            const lightbox = document.getElementById('lightbox');
            const content = document.getElementById('lightboxContent');

            // Build gallery images array from DOM
            if (galleryImages.length === 0) {
                const allGalleryItems = document.querySelectorAll('.gallery-item img[src*="gallery-"]');
                galleryImages = Array.from(allGalleryItems).map(img => img.src);
            }

            // Find current image index
            if (typeof imageSrc === 'string') {
                currentLightboxIndex = galleryImages.indexOf(imageSrc);
                if (currentLightboxIndex === -1) {
                    // Image not in gallery array, show it directly
                    content.innerHTML = `
                        <img src="${imageSrc}" alt="Gallery Image" onerror="this.src='https://via.placeholder.com/800x600?text=Image+Not+Found';">
                        ${caption ? `<p class="lightbox-caption">${caption}</p>` : ''}
                    `;
                    lightbox.classList.add('active');
                    document.body.style.overflow = 'hidden';
                    return;
                }
            }

            // Show image with navigation
            showLightboxImage(currentLightboxIndex, caption);
        }

        function showLightboxImage(index, caption) {
            const content = document.getElementById('lightboxContent');
            const lightbox = document.getElementById('lightbox');

            if (index < 0 || index >= galleryImages.length) return;

            const imgSrc = galleryImages[index];
            const altText = `Gallery ${index + 1}`;

            content.innerHTML = `
                <img src="${imgSrc}" alt="${altText}" onerror="this.src='https://via.placeholder.com/800x600?text=Image+Not+Found';">
                ${caption ? `<p class="lightbox-caption">${caption}</p>` : ''}
            `;
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox(event) {
            if (!event || event.target.id === 'lightbox' || event.target.classList.contains('lightbox-close')) {
                const lightbox = document.getElementById('lightbox');
                lightbox.classList.remove('active');
                document.getElementById('lightboxContent').innerHTML = '';
                document.body.style.overflow = 'auto';
                galleryImages = [];
                currentLightboxIndex = -1;
            }
        }

        function navigateLightbox(delta) {
            if (galleryImages.length === 0) return;

            currentLightboxIndex += delta;
            if (currentLightboxIndex < 0) currentLightboxIndex = galleryImages.length - 1;
            if (currentLightboxIndex >= galleryImages.length) currentLightboxIndex = 0;

            showLightboxImage(currentLightboxIndex);
        }

        // Keyboard navigation
        document.addEventListener('keydown', function(e) {
            const lightbox = document.getElementById('lightbox');
            if (!lightbox || !lightbox.classList.contains('active')) return;

            if (e.key === 'ArrowLeft') navigateLightbox(-1);
            if (e.key === 'ArrowRight') navigateLightbox(1);
            if (e.key === 'Escape') closeLightbox();
        });

        // ==================== SLIDESHOW FUNCTIONS ====================

        const slideState = {
            hytte: { current: 0, total: 3 },
            hus: { current: 0, total: 3 },
            doi: { current: 0, total: 4 }
        };

        function moveSlide(room, direction) {
            const state = slideState[room];
            state.current += direction;
            if (state.current < 0) state.current = state.total - 1;
            if (state.current >= state.total) state.current = 0;
            updateSlide(room);
        }

        function goToSlide(room, index) {
            slideState[room].current = index;
            updateSlide(room);
        }

        function updateSlide(room) {
            const state = slideState[room];
            const container = document.getElementById(room + '-slides');
            const dots = document.querySelectorAll(`#${room}-dots .slideshow-dot`);
            if (container) container.style.transform = `translateX(-${state.current * 100}%)`;
            dots.forEach((dot, index) => dot.classList.toggle('active', index === state.current));
        }

        function moveDoiSlide(direction) {
            moveSlide('doi', direction);
        }

        function goToDoiSlide(index) {
            goToSlide('doi', index);
        }

        // ==================== WEATHER FUNCTION ====================

        async function fetchUmphangWeather() {
            try {
                const response = await fetch('https://api.open-meteo.com/v1/forecast?latitude=15.7833&longitude=98.15&current_weather=true');
                const data = await response.json();
                if (data.current_weather) {
                    const temp = Math.round(data.current_weather.temperature);
                    document.getElementById('weatherTemp').textContent = `${temp}C`;
                    const weatherIcons = { 0: 'â€ď', 1: 'đď', 2: 'â', 3: 'âď', 45: 'đď', 51: 'đď', 61: 'đď', 80: 'đď', 95: 'âď' };
                    document.getElementById('weatherIcon').textContent = weatherIcons[data.current_weather.weathercode] || 'đď';
                }
            } catch (error) {
                console.error('Weather API error:', error);
                document.getElementById('weatherTemp').textContent = '30C';
                document.getElementById('weatherIcon').textContent = 'đď';
            }
        }

        // ==================== HERO BACKGROUND ====================

        function setHeroBackground() {
            const heroImages = ['hero-1.jpg', 'hero-2.jpg', 'hero-3.jpg', 'hero-4.jpg', 'hero-5.jpg', 'hero-6.jpg'];
            const today = new Date();
            const start = new Date(today.getFullYear(), 0, 0);
            const diff = today - start;
            const dayOfYear = Math.floor(diff / (1000 * 60 * 60 * 24));
            const selectedImage = heroImages[dayOfYear % heroImages.length];
            document.querySelector('.hero-bg').style.backgroundImage = `url('${selectedImage}')`;
        }

        // ==================== AI CHATBOT ====================

        let chatbotOpen = false;

        function toggleChatbot() {
            const chatbotWindow = document.getElementById('aiChatbotWindow');
            const chatbotBtn = document.getElementById('aiChatbotBtn');

            if (chatbotOpen) {
                chatbotWindow.style.display = 'none';
                chatbotBtn.innerHTML = '<span style="font-size: 1.25rem;">đ</span><span> AI</span>';
                chatbotOpen = false;
            } else {
                chatbotWindow.style.display = 'flex';
                chatbotBtn.innerHTML = '<span style="font-size: 1.25rem;">â</span><span></span>';
                chatbotOpen = true;
                setTimeout(() => document.getElementById('chatInput').focus(), 100);
            }
        }

        function sendChat() {
            const chatInput = document.getElementById('chatInput');
            const chatMessages = document.getElementById('chatMessages');
            const message = chatInput.value.trim();
            if (!message) return;

            const userMsg = document.createElement('div');
            userMsg.style.cssText = 'background: #1A1A1A; color: white; padding: 0.75rem; border-radius: 12px; margin-bottom: 0.75rem; align-self: flex-end; max-width: 80%;';
            userMsg.innerHTML = `<p style="margin: 0; font-size: 0.9rem;">${message}</p>`;
            chatMessages.appendChild(userMsg);
            chatInput.value = '';
            chatMessages.scrollTop = chatMessages.scrollHeight;

            setTimeout(() => {
                const response = generateAIResponse(message);
                const aiMsg = document.createElement('div');
                aiMsg.style.cssText = 'background: white; padding: 0.75rem; border-radius: 12px; margin-bottom: 0.75rem; box-shadow: 0 2px 8px rgba(0,0,0,0.05); max-width: 85%;';
                aiMsg.innerHTML = `<p style="margin: 0; font-size: 0.9rem; color: var(--dark-gray);">${response}</p>`;
                chatMessages.appendChild(aiMsg);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }, 500);
        }

        function generateAIResponse(message) {
            const msg = message.toLowerCase();
            if (msg.includes('') || msg.includes('') || msg.includes('hytte') || msg.includes('hus')) {
                if (msg.includes('')) return '<strong>đ :</strong><br>â€ €: 750-1,500/<br>â€ : 1,200-2,500/<br><br>High Season: ..-..<br>Green Season: ..-..';
                return '<strong>đ :</strong><br>â€ €: 5  <br>â€ : 1  <br><br> "" €!';
            }
            if (msg.includes('') || msg.includes('€') || msg.includes('')) {
                if (msg.includes('')) return '<strong>đď :</strong><br>đ VIP : 5,800-13,800<br>đ VIP -: 7,500-15,500<br>đ 4x4 : 2,500<br>âď 4x4 €: 1,850-2,500<br>đď : 1,000-1,500';
                return '<strong>đď :</strong><br>1. VIP  1 <br>2. VIP -<br>3.  4x4 <br>4.  4x4 €<br>5. ';
            }
            if (msg.includes('')) return '<strong>đ :</strong><br>đ 098-908-4356 ()<br>đ FB: Vela.umphang<br>đ vela.umphang@gmail.com';
            return '<strong>đ !</strong><br>€: , , , <br>€!';
        }

        // ==================== INITIALIZATION ====================

        document.addEventListener('DOMContentLoaded', function() {
            setHeroBackground();
            fetchUmphangWeather();

            // Initialize tour prices
            for (let i = 1; i <= 5; i++) {
                updateTourPrice(i);
            }

            // Set minimum date for tour booking
            const today = new Date().toISOString().split('T')[0];
            const tourDateInput = document.getElementById('tourBookingDate');
            if (tourDateInput) {
                tourDateInput.setAttribute('min', today);
            }
        });
    </script>

    <!-- Image Lightbox -->
    <div id="lightbox" class="lightbox">
        <div class="lightbox-content">
            <button class="lightbox-close" onclick="closeLightbox()"></button>
            <img id="lightbox-img" src="" alt="">
            <div id="lightbox-caption" class="lightbox-caption"></div>
        </div>
    </div>

    <script>
        // Lightbox Functions
        function openLightbox(imgSrc, caption) {
            document.getElementById('lightbox-img').src = imgSrc;
            document.getElementById('lightbox-caption').textContent = caption || '';
            document.getElementById('lightbox').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            document.getElementById('lightbox').classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close on background click
        document.getElementById('lightbox').addEventListener('click', function(e) {
            if (e.target === this) closeLightbox();
        });

        // Close on ESC key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeLightbox();
        });

        // Make all waterfall images clickable
        document.querySelectorAll('.hero-image-clickable').forEach(img => {
            img.addEventListener('click', function() {
                const caption = this.alt;
                openLightbox(this.src, caption);
            });
        });

        // Collapsible Waterfall Content
        function toggleWaterfall(id) {
            const content = document.getElementById('content-' + id);
            const btn = document.getElementById('btn-' + id);
            if (content && btn) {
                content.classList.toggle('active');
                btn.textContent = content.classList.contains('active') ? 'â ' : 'â ';
            }
        }
    </script>
</body>
</html>
