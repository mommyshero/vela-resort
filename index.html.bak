                <button onclick="openTourBookingModal(3)" class="btn btn-primary" style="width: 100%; padding: 1rem; background: #FFD700; color: #000000; border: 2px solid #FFD700; border-radius: 12px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.3s; margin-top: 0.75rem;">đ </button>
            </div>

            <!-- Tour 4:  4x4 € -->
            <div class="tour-card">
                <span class="tour-card-badge">4x4</span>
                <h4 class="tour-card-title">âď  4x4 €</h4>
                <p class="tour-card-route">€ (€ ~2 .)</p>
