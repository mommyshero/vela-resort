                <button onclick="openTourBookingModal(2)" class="btn btn-primary" style="width: 100%; padding: 1rem; background: #FFD700; color: #000000; border: 2px solid #FFD700; border-radius: 12px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.3s; margin-top: 0.75rem;">đ </button>
